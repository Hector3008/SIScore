<script>//filter de la lista productos
  const researchForm = document.querySelector("#researchForm");
  const input = document.querySelector("#search");
  socket = io()
  const productList = {{{ json products }}}; // array recibido por el .handlebars (html)

  input.addEventListener("input", (e) => {
    const search = e.target.value.toLowerCase().trim();
    // se convierte el string en tokens
    const tokens = search.split(/\s+/).filter(Boolean);
    // ej: "mitsubishi estator" -> ["mitsubishi","estator"]
    let list = productList;
    const filtered = list.filter(p => {
      const text = `
          ${p.CODIGO_FORMATEADO}
          ${p.CODIGO}
          ${p.DESCRIPCION}
          ${p.PROVEEDOR}
          ${p.MARCA}
          ${p.SUBFAMILIA}
          ${p.FAMILIA}
        `.toLowerCase();
      // 👇 TODAS las palabras deben existir
      return tokens.every(word => text.includes(word));
    });
    socket.emit("filterRequest", filtered);
  });
</script>

