                      <td>${prod.cantidad}</td>
                      <td>${prod.comentario}</td>
                                    <td>${prod.importe}</td>
                      <td>${prod.total}</td>
                `
                productTable.appendChild(tr);
              }
            }
            productTablePreview.innerHTML =""
            productListPreview = productListArray.filter(
              prod => prod.status === true || prod.status === "true"
            );
            //console.log("productListPreview: ", productListPreview)
            productListPreview.map((prod, index) => {
