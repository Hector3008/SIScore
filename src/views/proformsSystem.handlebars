<div>
  <h2>previsualizacion de proforma</h2>
</div>


<script src="/socket.io/socket.io.js"></script>

<script>//filter de la lista productos
  const researchForm = document.querySelector("#researchForm");
  const input = document.querySelector("#search");
  socket = io()
  const productList = {{{ json products }}}; // array recibido por el .handlebars (html)

  input.addEventListener("input", (e) => {
    const search = e.target.value.toLowerCase().trim();
    // se convierte el string en tokens
    const tokens = search.split(/\s+/).filter(Boolean);
    // ej: "mitsubishi estator" -> ["mitsubishi","estator"]
    let list = productList;
    const filtered = list.filter(p => {
      const text = `
          ${p.CODIGO_FORMATEADO}
          ${p.CODIGO}
          ${p.DESCRIPCION}
          ${p.PROVEEDOR}
          ${p.MARCA}
          ${p.SUBFAMILIA}
          ${p.FAMILIA}
        `.toLowerCase();
      // 👇 TODAS las palabras deben existir
      return tokens.every(word => text.includes(word));
    });
    socket.emit("filterRequest", filtered);
  });
</script>

<script>//print de la tabla productos
  const table = document.querySelector("#tbbodyProducts")

  socket.on("filterList", (data) => {

    table.innerHTML = ""
    for (product of data) {

      let tr = document.createElement("tr");
      tr.innerHTML = `
                      
        <td>${product.status}</td>
        <td>${product.ID}</td>
        <td>${product.CODIGO_FORMATEADO}</td>
        <td>${product.CODIGO}</td>
        <td>${product.STOCK_LV}</td>
        <td>${product.STOCK_SJL}</td>
        <td>${product.STOCK}</td>
        <td>${product.EQUIVALENTES_STOCK}</td>
        
        <td>${product.DESCRIPCION}</td>
        
        <td>${product.FAMILIA}</td>
        
        <td>${product.SUBFAMILIA}</td>
        
        <td>${product.PROVEEDOR}</td>
        
        <td>${product.MARCA}</td>
      `;
      tbbodyProducts.appendChild(tr);
    }

  })
</script>

<script>//post de la lista pagos
  const cargarPagoBtn = document.querySelector("#cargarPagoBtn")
  cargarPagoBtn.addEventListener("click",(e)=>{
    
    const monto = document.querySelector("#form-pagos-montos-field").value
    const operacion = document.querySelector("#form-pagos-operacion-field").value
    const medio = document.querySelector("#form-pagos-medio-field").value

  const pago = {monto, operacion, medio}
    socket.emit("cargarPagoBtn", pago)
  })
</script>

<script>//print de la tabla pagos
  const tablePagos = document.querySelector("#tbbodyPagos")
  socket.on("pagos",(data)=>{
    
    const pagos = document.querySelectorAll(".pagoTr")//devuelve un objeto nodeList
       
    const pagosArray = Array.from(pagos)//lo convertimos en array y lo formateamos
    .map((tr,index) => {
      const tds = tr.querySelectorAll("td");
      return {
        index: index + 1,
        medio: tds[1].textContent.trim(),
        monto: tds[2].textContent.replace(" /S", "").trim(),
        operacion: tds[3].textContent.trim()
      };
    });
    pagosArray.push({index: pagosArray.length +1 ,medio: data.medio, monto: data.monto, operacion: data.operacion})
    console.log("pagosArray 2: ", pagosArray)
    
    tablePagos.innerHTML = ""

    for (pago of pagosArray) {
    const tr = document.createElement("tr");
    tr.classList.add("pagoTr");
    tr.id = `pago-${pago.index}-tr`
        tr.innerHTML = `
              <td>
                <button id="delete-btn-pago-${pago.index}">eliminar</button>
              </td>
              <td>${pago.medio}</td>
              <td>${pago.monto} /S</td>
              <td>${pago.operacion}</td>
              <td><button>editar</button></td>
        `
  tablePagos.appendChild(tr);  }
  })

// ✅ listener global (solo una vez)
tablePagos.addEventListener("click", (e) => {
  if (e.target.id.startsWith("delete-btn-pago-")) {
    const tr = e.target.closest("tr");
    tr.remove();
  }
});

</script>

