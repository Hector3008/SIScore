<div class="proforma-app">

  {{!-- HEADER --}}
  <header class="proforma-header">
    <div class="header-left">
      <img src="/img/logo.png" class="logo" />
      <div class="empresa-info">
        <h2>Max Importaciones y Servicios Generales SAC</h2>
        <p>RUC: 20503534194</p>
        <p>Cel: 999 999 999</p>
        <p>ventas@maximportaciones.com.pe</p>
      </div>
    </div>

    <div class="header-right">
      <div class="proforma-box">
        <span>PROFORMA N°</span>
        <h1>DP-000009</h1>
        <span>FECHA: 23/02/2026</span>
      </div>
    </div>
  </header>

  {{!-- BODY --}}
  <div class="proforma-body">

  {{!--  <!-- MAIN --> --}}
    <main class="main-panel">

    {{!-- <!-- CLIENTE --> --}}
      <section class="block">
        <div class="block-title">CLIENTE / FORMULARIO</div>

        <div class="grid-4">
          <input placeholder="Cliente">
          <input placeholder="RUC">
          <input placeholder="Teléfono">
          <input placeholder="E-mail">

          <input placeholder="Dirección">
          <input placeholder="Provincia">
          <input placeholder="Ciudad">
          <select>
            <option>Asesor de venta</option>
          </select>

          <input placeholder="Entrega">
          <input placeholder="Destino">
          <input placeholder="Agencia">
          <input placeholder="Atención">

          <select>
            <option>Canal de venta</option>
          </select>
          <select>
            <option>Forma de pago</option>
          </select>
          <input placeholder="Fecha">
        </div>

        <div class="btn-row">
          <button class="btn green">Cargar cliente</button>
          <button class="btn blue">Registrar cliente</button>
          <button class="btn orange">Actualizar cliente</button>
        </div>
      </section>

      {{!-- OTROS MEDIOS DE PAGO --}}
      <section class="block">
        <div class="block-title">OTROS MEDIOS DE PAGO</div>

        <div class="grid-3">
          <select>
            <option>Forma de pago</option>
          </select>
          <input placeholder="Monto">
          <input placeholder="N° operación">
        </div>

        <div class="btn-row">
          <button class="btn red">Borrar medio</button>
          <button class="btn green">Cargar medio</button>
        </div>
      </section>

      {{!-- PRODUCTOS --}}
      <section class="block">
        <div class="block-title">PRODUCTOS / FORMULARIO</div>

        <table class="table">
          <thead>
            <tr>
              <th>Cantidad</th>
              <th>Producto</th>
        
              <th>Comentario</th>
              <th>Importe Unit.</th>
              <th>Total</th>
            </tr>
          </thead>
          <tbody id="productosTable"></tbody>
            <h2>formulario productos</h2>
            
            <form type="onsubmit" id="researchForm">
              <div class="m-2 form-label">producto: <input type="text" class="form-control" id="search"></div>
            </form>
        </table>
      </section>

    </main>

    {{!-- PANEL DERECHO --}}
    <aside class="side-panel">
      <button class="side-btn orange">REFRESCAR DDBB</button>
      <button class="side-btn green">CONSULTAR PROFORMA</button>
      <button class="side-btn lime">ACTUALIZAR PROFORMA</button>
      <button class="side-btn dark">IMPRIMIR</button>

      <div class="check-group">
        <label><input type="checkbox"> Proforma</label>
        <label><input type="checkbox"> Guía almacén</label>
      </div>

      <button class="side-btn green">DESCARGAR</button>

      <div class="check-group">
        <label><input type="checkbox"> Proforma</label>
        <label><input type="checkbox"> Guía almacén</label>
      </div>

      <button class="side-btn orange" id="postProformBtn">CARGAR PROFORMA</button>
      <button class="side-btn red">REINICIAR</button>
    </aside>

  </div>
</div>

