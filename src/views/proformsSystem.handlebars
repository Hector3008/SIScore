<script>//post de la lista pagos
  const cargarPagoBtn = document.querySelector("#cargarPagoBtn")
  cargarPagoBtn.addEventListener("click", (e) => {

    const monto = document.querySelector("#form-pagos-montos-field").value
    const operacion = document.querySelector("#form-pagos-operacion-field").value
    const medio = document.querySelector("#form-pagos-medio-field").value

    const pago = { monto, operacion, medio }
    socket.emit("cargarPagoBtn", pago)

    document.querySelector("#form-pagos-montos-field").value = ""
    document.querySelector("#form-pagos-operacion-field").value = ""
    document.querySelector("#form-pagos-medio-field").value = ""
  })
</script>

<script>//print de la tabla pagos:
  const tablePagos = document.querySelector("#tbbodyPagos")
  const previewPagos = document.querySelector("#preview-pagos")
  socket.on("pagos", (data) => {
    previewPagos.innerHTML = ""
    const pagos = document.querySelectorAll(".pagoTr")//devuelve un objeto nodeList

    const pagosArray = Array.from(pagos)//lo convertimos en array y lo formateamos
      .map((tr, index) => {
        const tds = tr.querySelectorAll("td");
        return {
          index: index + 1,
          medio: tds[1].textContent.trim(),
          monto: tds[2].textContent.replace(" /S", "").trim(),
          operacion: tds[3].textContent.trim()
        };
      });
    pagosArray.push({ index: pagosArray.length + 1, medio: data.medio, monto: data.monto, operacion: data.operacion })

    tablePagos.innerHTML = ""


    for (pago of pagosArray) {

      const tr = document.createElement("tr");

      tr.classList.add("pagoTr");
      tr.id = `pago-${pago.index}-tr`
      tr.innerHTML = `
      
              <td>
                <button id="delete-btn-pago-${pago.index}">eliminar</button>
              </td>
              <td>${pago.medio}</td>
              <td>${pago.monto} /S</td>
              <td>${pago.operacion}</td>
              <td><button>editar</button></td>
        `
      tablePagos.appendChild(tr);

      let span = document.createElement("span");
      span.id = `preview-client-pago-${pago.index}-span`
      span.innerHTML = ` ${pago.medio} - ${pago.monto} /S - op ${pago.operacion} | `
      previewPagos.appendChild(span)
      console.log("previewPagos from event: ", previewPagos)
    }

  })

  // ✅ listener global (solo una vez)
  tablePagos.addEventListener("click", (e) => {
    if (e.target.id.startsWith("delete-btn-pago-")) {
      const tr = e.target.closest("tr");
      console.log("tr.id: ", tr.id.split("-")[1])
      const id = tr.id.split("-")[1]

      const spanToRemove = document.querySelector(`#preview-client-pago-${id}-span`)

      spanToRemove.remove()
      tr.remove();
    }
  });

</script>

