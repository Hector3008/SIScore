        <script>//cargarProductoBtn
let productListArray = []
let  productListPreview = []
          const cargarProductoBtn = document.querySelector("#cargarProductoBtn")
          const productTablePreview = document.querySelector("#tbody-products-proform-preview")
          const productTable = document.querySelector("#productList")

          cargarProductoBtn.addEventListener("click", (e) => {
            e.preventDefault();

            const productList = document.querySelectorAll(".productListItem")

            const nombre = document.querySelector("#search").value
            const cantidad = document.querySelector("#form-product-cantidad-field").value
            const importe = document.querySelector("#form-product-importe-unitario-field").value
            const comentario = document.querySelector("#form-product-comentario-field").value

            const product = {
              status: true,
              nombre,
              cantidad,
              importe,
              comentario,
              total: cantidad * importe
            }

            
            productListArray = Array.from(productList).map((tr, index) => {
              const tds = tr.querySelectorAll("td");
              // console.log("tds: ", tds)
              return {
                index: tds[0].textContent,
                status: tds[1].textContent.trim(),
                nombre: tds[2].textContent.trim(),
                cantidad: tds[3].textContent.trim(),
                comentario: tds[4].textContent.trim(),
                importe: tds[5].textContent.trim(),
                total: tds[3].textContent.trim() * tds[5].textContent.trim()
              };
            }
            );
            product.index = productListArray.length + 1
            productListArray.push(product)

            productTable.innerHTML = ""
            productTablePreview.innerHTML = ""
            for (prod of productListArray) {

              const tr = document.createElement("tr");

              tr.classList.add("productListItem");
              tr.id = `product-${prod.index}-tr`

              tr.innerHTML = `
                      <td>${prod.index}</td>      
                      <td>${prod.status}</td>
                      <td>${prod.nombre}</td>
                      <td>${prod.cantidad}</td>
                      <td>${prod.comentario}</td>
                                    <td>${prod.importe}</td>
                      <td>${prod.total}</td>
                `
              productTable.appendChild(tr);
            }

            //console.log("productListArray: ", productListArray)
            productListPreview = productListArray.filter(
              prod => prod.status === true || prod.status === "true"
            );
            //console.log("productListPreview: ", productListPreview)
            productListPreview.map((prod, index) => {
              const tr = document.createElement("tr");

              tr.classList.add("previewProductListItem")
              tr.id = `preview-product-${prod.index}-tr`

              tr.innerHTML = `
                      <td>
                      <button id="delete-btn-product-${prod.index}">
                      eliminar
                      </button>${index + 1}</td>
                                    <td>${prod.cantidad}</td>
                                    <td>${prod.nombre}</td>
                                    <td>${prod.importe}</td>
                                    <td>${prod.total}</td>
                      `
              productTablePreview.appendChild(tr)

            })


            document.querySelector("#search").value =""
            document.querySelector("#form-product-cantidad-field").value=""
            document.querySelector("#form-product-importe-unitario-field").value=""
            document.querySelector("#form-product-comentario-field").value=""
          }

          )

          const tbodyPreviewProducts = document.querySelector("#tbody-products-proform-preview");
          console.log("tbody:", tbodyPreviewProducts);

          document.querySelector("#tbody-products-proform-preview").addEventListener("click", (e) => {
            console.log("productListArray here: ", productListArray)

            
            if (e.target.id.startsWith("delete-btn-product-")) {
              console.log("e.target.id: ", e.target.id)
              
              const tr = e.target.closest("tr");
              const id = tr.id.split("-")[2]
              console.log("productListArray 1: ", productListArray)

              productListArray = productListArray.map(prod => {
                if (prod.index == id) {
                  return {
                    ...prod,
                    status: false
                  };
                }
                return prod;
              })
              console.log("productListArray 2",productListArray)

              productTable.innerHTML =""
              //tr.remove()

              for(prod of productListArray){
                const tr = document.createElement("tr");

                tr.classList.add("productListItem");
