<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Revisión</title>
  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: sans-serif;
      background: #f1f0ea;
      height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* ── TOPBAR GLOBAL ─────────────────────────────────────── */
    .global-topbar {
      background: #0f3460;
      padding: 0 20px;
      height: 48px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-shrink: 0;
    }

    .global-topbar .brand {
      font-size: 14px;
      font-weight: 600;
      color: #fff;
    }

    .global-topbar .brand span {
      font-weight: 400;
      opacity: 0.6;
      font-size: 12px;
      margin-left: 8px;
    }

    /* ── LAYOUT PRINCIPAL ──────────────────────────────────── */
    .layout {
      display: flex;
      flex: 1;
      overflow: hidden;
    }

    /* ── SIDEBAR ───────────────────────────────────────────── */
    .sidebar {
      width: 230px;
      min-width: 230px;
      background: #fff;
      border-right: 0.5px solid #e0ddd4;
      display: flex;
      flex-direction: column;
    }

    .sidebar-header {
      padding: 14px 14px 10px;
      border-bottom: 0.5px solid #e0ddd4;
    }

    .sidebar-header p {
      font-size: 11px;
      color: #888780;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-bottom: 8px;
    }

    .search-box {
      width: 100%;
      padding: 6px 10px;
      border: 0.5px solid #c8c6be;
      border-radius: 8px;
      font-size: 12px;
      background: #f5f4ef;
      color: #2c2c2a;
      outline: none;
    }

    .search-box:focus {
      border-color: #185FA5;
    }

    .orders-list {
      flex: 1;
      overflow-y: auto;
      padding: 8px;
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    /* ── ORDER CARD ────────────────────────────────────────── */
    .order-card {
      padding: 10px 12px;
      border-radius: 8px;
      border: 0.5px solid #e0ddd4;
      background: #fff;
      cursor: pointer;
      transition: border-color 0.15s;
    }

    .order-card:hover {
      border-color: #b4b2a9;
    }

    .order-card.active {
      border-color: #185FA5;
      background: #E6F1FB;
    }

    .order-card.active .order-id {
      color: #185FA5;
    }

    .order-id {
      font-size: 13px;
      font-weight: 500;
      color: #2c2c2a;
      margin-bottom: 4px;
    }

    .order-meta {
      font-size: 11px;
      color: #5f5e5a;
      display: flex;
      justify-content: space-between;
    }

    /* ── BADGES ────────────────────────────────────────────── */
    .badge {
      display: inline-block;
      font-size: 10px;
      padding: 2px 7px;
      border-radius: 99px;
      margin-top: 5px;
      background: #E6F1FB;
      color: #185FA5;
    }

    .badge.pending {
      background: #FAEEDA;
      color: #854F0B;
    }

    .badge.inactive {
      background: #F1EFE8;
      color: #5f5e5a;
    }

    /* ── MAIN ──────────────────────────────────────────────── */
    .main {
      flex: 1;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    /* ── DOC TOPBAR ────────────────────────────────────────── */
    .doc-topbar {
      background: #0f3460;
      padding: 0 16px;
      height: 48px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-shrink: 0;
    }

    .doc-info .doc-code {
      font-size: 14px;
      font-weight: 500;
      color: #fff;
    }

    .doc-info .doc-code .version {
      font-size: 11px;
      font-weight: 400;
      opacity: 0.55;
    }

    .doc-info .doc-date {
      font-size: 11px;
      color: rgba(255, 255, 255, 0.55);
    }

    /* ── TAB SWITCHER ──────────────────────────────────────── */
    .tab-switcher {
      display: flex;
      border: 0.5px solid rgba(255, 255, 255, 0.25);
      border-radius: 8px;
      overflow: hidden;
    }

    .tab-btn {
      padding: 5px 18px;
      font-size: 12px;
      background: transparent;
      border: none;
      color: rgba(255, 255, 255, 0.65);
      cursor: pointer;
      transition: background 0.15s;
    }

    .tab-btn.active {
      background: rgba(255, 255, 255, 0.18);
      color: #fff;
    }

    /* ── ACTION BUTTONS ────────────────────────────────────── */
    .tab-actions {
      display: flex;
      gap: 6px;
      align-items: center;
    }

    .act-btn {
      padding: 5px 12px;
      font-size: 12px;
      border-radius: 8px;
      border: 0.5px solid rgba(255, 255, 255, 0.3);
      background: transparent;
      color: rgba(255, 255, 255, 0.85);
      cursor: pointer;
      transition: background 0.15s;
    }

    .act-btn:hover {
      background: rgba(255, 255, 255, 0.1);
    }

    .act-btn.primary {
      background: rgba(255, 255, 255, 0.15);
    }

    /* ── DOC AREA ──────────────────────────────────────────── */
    .doc-area {
      flex: 1;
      overflow-y: auto;
      padding: 16px 20px;
    }

    /* ── TAB PANELS ────────────────────────────────────────── */
    .tab-panel {
      display: none;
    }

    .tab-panel.active {
      display: block;
    }

    /* ── PREVIEW CARD (del main original) ──────────────────── */
    .preview-card {
      background: #fff;
      border-radius: 10px;
      border: 1px solid #e0e0e0;
      padding: 20px;
    }

    .preview-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 16px;
      padding-bottom: 14px;
      border-bottom: 1px solid #eee;
      flex-wrap: wrap;
      gap: 12px;
    }

    .ph-left {
      display: flex;
      gap: 12px;
      flex: 1;
      min-width: 200px;
    }

    .logo-box {
      width: 56px;
      height: 56px;
      background: #f5f5f5;
      border: 1px solid #ddd;
      border-radius: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 9px;
      color: #aaa;
      flex-shrink: 0;
    }

    .ph-info strong {
      font-size: 12px;
      font-weight: 600;
      color: #222;
      display: block;
      margin-bottom: 2px;
    }

    .ph-info p {
      font-size: 11px;
      color: #666;
      line-height: 1.7;
    }

    .ph-right {
      text-align: right;
    }

    .doc-num {
      font-size: 22px;
      font-weight: 600;
      color: #0f4c81;
    }

    .doc-meta {
      font-size: 11px;
      color: #888;
      margin-top: 2px;
    }

    .client-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3px 24px;
      margin-bottom: 16px;
    }

    @media (max-width: 520px) {
      .client-grid {
        grid-template-columns: 1fr;
      }
    }

    .cl {
      font-size: 11px;
      color: #555;
      display: flex;
      gap: 4px;
    }

    .cl span:first-child {
      font-weight: 600;
      color: #333;
      min-width: 72px;
      flex-shrink: 0;
    }

    .table-wrap {
      width: 100%;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }

    .items-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 11px;
      margin-bottom: 14px;
      min-width: 480px;
    }

    .items-table th {
      background: #0f4c81;
      color: #fff;
      padding: 7px 8px;
      text-align: left;
      font-weight: 500;
      white-space: nowrap;
    }

    .items-table td {
      padding: 6px 8px;
      border-bottom: 1px solid #eee;
      color: #333;
    }

    .items-table tr:nth-child(even) td {
      background: #f9f9f9;
    }

    .btn-eliminar {
      font-size: 10px;
      padding: 2px 6px;
      border: 1px solid #ddd;
      border-radius: 4px;
      background: #fff;
      cursor: pointer;
      color: #c62828;
    }

    .totals {
      display: flex;
      justify-content: flex-end;
      margin-top: 4px;
    }

    .totals-box {
      width: 220px;
    }

    @media (max-width: 520px) {
      .totals-box {
        width: 100%;
      }
    }

    .total-row {
      display: flex;
      justify-content: space-between;
      font-size: 11px;
      padding: 3px 0;
      color: #666;
    }

    .total-final {
      display: flex;
      justify-content: space-between;
      font-size: 13px;
      font-weight: 600;
      padding: 7px 10px;
      background: #e85d14;
      color: #fff;
      border-radius: 6px;
      margin-top: 5px;
    }

    .preview-footer {
      margin-top: 20px;
      padding-top: 12px;
      border-top: 1px solid #eee;
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 10px;
    }

    @media (max-width: 600px) {
      .preview-footer {
        grid-template-columns: 1fr;
      }
    }

    .preview-footer strong {
      font-size: 10px;
      color: #555;
      font-weight: 600;
      display: block;
      margin-bottom: 2px;
    }

    .preview-footer p {
      font-size: 10px;
      color: #888;
    }

    .guia-header {
      background: #1a3a5c;
      color: #fff;
      padding: 8px 12px;
      border-radius: 6px;
      display: flex;
      justify-content: space-between;
      font-size: 11px;
      margin-bottom: 14px;
      flex-wrap: wrap;
      gap: 6px;
    }

    .badge-ok {
      background: #e8f5e9;
      color: #2e7d32;
    }

    .badge-warn {
      background: #fff8e1;
      color: #f57f17;
    }
  </style>
</head>

<body>

  <!-- TOPBAR GLOBAL -->
  <div class="global-topbar">
    <div class="brand">
      Max Importaciones y Servicios Generales S.A.C <span>Revisión de órdenes</span>
    </div>
  </div>

  <!-- LAYOUT -->
  <div class="layout">

    <!-- SIDEBAR -->
    <div class="sidebar">
      <div class="sidebar-header">
        <p>Órdenes</p>
        <input class="search-box" type="text" placeholder="Buscar orden..." id="searchInput" />
      </div>

      <div class="orders-list" id="ordersList"></div>
    </div>

    <!-- MAIN -->
    <div class="main">

      <!-- DOC TOPBAR -->
      <div class="doc-topbar">
        <div class="doc-info">
          <div class="doc-code">
            {{ordenActiva.codigo}} <span class="version">v{{ordenActiva.version}}</span>
          </div>
          <div class="doc-date">{{ordenActiva.fecha}} · {{ordenActiva.vendedor}}</div>
        </div>

        <div class="tab-switcher">
          <button class="tab-btn active" data-tab="proforma">Proforma</button>
          <button class="tab-btn" data-tab="guia">Guía</button>
        </div>

        <div class="tab-actions">
          <button class="act-btn">Imprimir</button>
          <button class="act-btn">Descargar</button>
          <button class="act-btn primary">Aprobar</button>
        </div>
      </div>

      <!-- DOC AREA -->
      <div class="doc-area">

        <!-- PANEL PROFORMA -->
        <div class="tab-panel active" id="panel-proforma">
          <div class="preview-card">

            <div class="preview-header">
              <div class="ph-left">
                <div class="logo-box">LOGO</div>
                <div class="ph-info">
                  <strong id="proforma_empresa_nombre">Max Importaciones y Servicios Generales SAC</strong>
                  <p>RUC: <span id="proforma_empresa_ruc">20503534194</span></p>
                  <p id="proforma_empresa_direccion">Av. García Naranjo Nro. 114b - La Victoria - Lima</p>
                  <p id="proforma_empresa_telefono">Tel: 999 999 999</p>
                  <p id="proforma_empresa_email">ventas@maximportaciones.com.pe</p>
                  <p id="proforma_empresa_web">https://maximportaciones.com.pe</p>
                </div>
              </div>
              <div class="ph-right">
                <div><span class="doc-num">DP-0000001</span> <span id="proforma_version"></span></div>
                <div class="doc-meta">Fecha: <span id="proforma_fecha"></span></div>
              </div>
            </div>

            <div class="client-grid">
              <div class="cl"><span>Cliente:</span><span id="proforma_cliente_nombre"></span></div>
              <div class="cl"><span>Teléfono:</span><span id="proforma_cliente_telefono"></span></div>
              <div class="cl"><span>RUC/DNI:</span><span id="proforma_cliente_ruc"></span></div>
              <div class="cl"><span>Mail:</span><span id="proforma_cliente_email"></span></div>
              <div class="cl"><span>Dirección:</span><span id="proforma_cliente_direccion"></span></div>
              <div class="cl"><span>Entrega:</span><span id="proforma_entrega"></span></div>
              <div class="cl"><span>Provincia:</span><span id="proforma_cliente_provincia"></span></div>
              <div class="cl"><span>Ciudad:</span><span id="proforma_cliente_ciudad"></span></div>
              <div class="cl"><span>Destino:</span><span id="proforma_destino"></span></div>
              <div class="cl"><span>Canal de venta:</span><span id="proforma_canal_de_venta"></span></div>
              <div class="cl"><span>Forma pago:</span><span id="proforma_forma_de_pago"></span></div>
              <div class="cl"><span>Comprobante:</span><span id="proforma_comprobante"></span></div>
              <div class="cl"><span>Agencia:</span><span id="proforma_agencia"></span></div>
              <div class="cl"><span>Atención:</span><span id="proforma_atencion"></span></div>
              <div class="cl"><span>Vendedor:</span><span id="proforma_vendedor"></span></div>
              <div class="cl"><span>Pagos:</span><span id="proforma_pagos"></span></div>
            </div>

            <div class="table-wrap">
              <table class="items-table">
                <thead>
                  <tr>
                    <th>#</th>
                    <th>Descripción</th>
                    <th>Cantidad</th>
                    <th>Precio unit.</th>
                    <th>Importe</th>
                    <th></th>
                  </tr>
                </thead>
                <tbody id="tbody_proforma"></tbody>
              </table>
            </div>

            <div class="totals">
              <div class="totals-box">
                <div class="total-row"><span>Subtotal</span><span id="subtotal">S/ 0.00</span></div>
                <div class="total-row"><span>IGV (18%)</span><span id="igv">S/ 0.00</span></div>
                <div class="total-final"><span>Importe total</span><span id="total">S/ 0.00</span></div>
              </div>
            </div>

            <div class="preview-footer">
              <div>
                <strong>Condiciones</strong>
                <p>Precios sujetos a cambio sin previo aviso.</p>
              </div>
              <div>
                <strong>Observaciones</strong>
                <p>—</p>
              </div>
              <div>
                <strong>Contacto</strong>
                <p>999 999 999</p>
                <p>ventas@maximportaciones.com.pe</p>
              </div>
            </div>

          </div>
        </div>
        <!-- /PANEL PROFORMA -->

        <!-- PANEL GUÍA -->
        <div class="tab-panel" id="panel-guia">
          <div class="preview-card">

            <div class="guia-header">
              <span>CLIENTE: <span id="guia_cliente"></span></span>
              <span>VENDEDOR: <span id="guia_vendedor"></span></span>
              <span>Fecha: <span id="guia_fecha"></span></span>
              <span><span class="doc-num" style="font-size:14px" id="guia_codigo">DP-0000001</span> <span
                  id="guia_version"></span></span>
            </div>

            <div class="table-wrap">
              <table class="items-table" style="min-width:700px">
                <thead>
                  <tr>
                    <th>Item</th>
                    <th>Cant.</th>
                    <th>Precio uni</th>
                    <th>Pedid</th>
                    <th>Comentario</th>
                    <th>Opciones</th>
                    <th>LV</th>
                    <th>SJL</th>
                    <th>Descripción</th>
                    <th>Equivalente</th>
                    <th>Ubicación</th>
                  </tr>
                </thead>
                <tbody id="tbody-guia"></tbody>
              </table>
            </div>

            <div class="preview-footer">
              <div>
                <strong>Condiciones</strong>
                <p>Precios sujetos a cambio sin previo aviso.</p>
              </div>
              <div>
                <strong>Observaciones</strong>
                <p>—</p>
              </div>
              <div>
                <strong>Contacto</strong>
                <p>999 999 999</p>
              </div>
            </div>

          </div>
        </div>
        <!-- /PANEL GUÍA -->

      </div>
      <!-- /DOC AREA -->

    </div>
    <!-- /MAIN -->

  </div>
  <!-- /LAYOUT -->

  <script src="/socket.io/socket.io.js"></script>
  <script>
    const socket = io();
    const proformsJSON = {{{ json proforms }}}
    const currentProform = {}

    const orders = document.querySelector("#ordersList")

    function printCards(proforms) {
      proforms = proforms.filter((proform) => proform.payload.doc.tipo == "orden_revision")
      orders.innerHTML = ""
      for (let proform of proforms) {
        const card = document.createElement("div")
        card.classList.add("order-card")
        card.dataset.id = proform.payload.doc.code

        card.innerHTML = `
          <div class="order-id">${proform.payload.doc.code}</div>
          <div class="order-meta">
            <span>${proform.payload.doc.cliente.nombre}</span>
            <span>${proform.payload.doc.fecha}</span>
          </div>
          <div><span class="order-meta">${proform.payload.doc.vendedor}</span></div>
          <span class="badge">activa</span>
        `
        orders.appendChild(card)
      }
    }

    printCards(proformsJSON)

    // ── TAB SWITCHER ──────────────────────────────────────────
    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
        btn.classList.add('active');
        document.getElementById('panel-' + btn.dataset.tab).classList.add('active');
      });
    });

    // ── ORDER CARD SELECTION ──────────────────────────────────
    document.querySelectorAll('.order-card').forEach(card => {
      card.addEventListener('click', () => {
        document.querySelectorAll('.order-card').forEach(c => c.classList.remove('active'));
        card.classList.add('active');
        console.log('Orden seleccionada:', card.dataset.id);

        //aquí debo conectar con la lógica del printGuia y printProforma
      });
    });

    // ── SEARCH FILTER ─────────────────────────────────────────
    document.getElementById('searchInput').addEventListener('input', function () {
      const q = this.value.toLowerCase();
      document.querySelectorAll('.order-card').forEach(card => {
        card.style.display = card.textContent.toLowerCase().includes(q) ? '' : 'none';
      });
    });
  </script>

</body>

</html>