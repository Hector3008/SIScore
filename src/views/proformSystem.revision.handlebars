<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Revisión</title>
  <style>
.solo-tablet {
  display: none;
}

@media (max-width: 1024px) {
  .solo-tablet {
    display: flex;
  }
}
.fila-aprobada {
  background-color: #d4edda !important;
}

.fila-aprobada td {
  background-color: #d4edda !important;
}
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: sans-serif;
      background: #f1f0ea;
      height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* ── TOPBAR GLOBAL ─────────────────────────────────────── */
    .global-topbar {
      background: #0d1b3e;
      padding: 0 20px;
      height: 48px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-shrink: 0;
    }

    .global-topbar .brand {
      font-size: 14px;
      font-weight: 600;
      color: #fff;
    }

    .global-topbar .brand span {
      font-weight: 400;
      opacity: 0.6;
      font-size: 12px;
      margin-left: 8px;
    }

    /* ── LAYOUT PRINCIPAL ──────────────────────────────────── */
    .layout {
      display: flex;
      flex: 1;
      overflow: hidden;
    }

    /* ── SIDEBAR ───────────────────────────────────────────── */
    .sidebar {
      width: 230px;
      min-width: 230px;
      background: #fff;
      border-right: 0.5px solid #e0ddd4;
      display: flex;
      flex-direction: column;
    }

    .sidebar-header {
      padding: 14px 14px 10px;
      border-bottom: 0.5px solid #e0ddd4;
    }

    .sidebar-header p {
      font-size: 11px;
      color: #888780;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-bottom: 8px;
    }

    .search-box {
      width: 100%;
      padding: 6px 10px;
      border: 0.5px solid #c8c6be;
      border-radius: 8px;
      font-size: 12px;
      background: #f5f4ef;
      color: #2c2c2a;
      outline: none;
    }

    .search-box:focus {
      border-color: #185FA5;
    }

    .orders-list {
      flex: 1;
      overflow-y: auto;
      padding: 8px;
      display: flex;
      flex-direction: column;
      gap: 6px;
      scrollbar-width: thin;
      scrollbar-color: #c8c6be #f5f4ef;
    }

    .orders-list::-webkit-scrollbar {
      width: 8px;
    }

    .orders-list::-webkit-scrollbar-track {
      background: #f5f4ef;
    }

    .orders-list::-webkit-scrollbar-thumb {
      background: #c8c6be;
      border-radius: 4px;
    }

    .orders-list::-webkit-scrollbar-thumb:hover {
      background: #b4b2a9;
    }

    /* ── ORDER CARD ────────────────────────────────────────── */
    .order-card {
      padding: 10px 12px;
      border-radius: 8px;
      border: 0.5px solid #e0ddd4;
      background: #fff;
      cursor: pointer;
      transition: border-color 0.15s;
    }

    .order-card:hover {
      border-color: #b4b2a9;
    }

    .order-card.active {
      border-color: #185FA5;
      background: #E6F1FB;
    }

    .order-card.active .order-id {
      color: #185FA5;
    }

    .order-id {
      font-size: 13px;
      font-weight: 500;
      color: #2c2c2a;
      margin-bottom: 4px;
    }

    .order-meta {
      font-size: 11px;
      color: #5f5e5a;
      display: flex;
      justify-content: space-between;
    }

    /* ── BADGES ────────────────────────────────────────────── */
    .badge {
      display: inline-block;
      font-size: 10px;
      padding: 2px 7px;
      border-radius: 99px;
      margin-top: 5px;
      background: #E6F1FB;
      color: #185FA5;
    }

    .badge.pending {
      background: #FAEEDA;
      color: #854F0B;
    }

    .badge.inactive {
      background: #F1EFE8;
      color: #5f5e5a;
    }

    /* ── MAIN ──────────────────────────────────────────────── */
    .main {
      flex: 1;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    /* ── DOC TOPBAR ────────────────────────────────────────── */
    .doc-topbar {
      background: #0d1b3e;
      padding: 0 16px;
      height: 48px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-shrink: 0;
    }

    .doc-info .doc-code {
      font-size: 14px;
      font-weight: 500;
      color: #fff;
    }

    .doc-info .doc-code .version {
      font-size: 11px;
      font-weight: 400;
      opacity: 0.55;
    }

    .doc-info .doc-date {
      font-size: 11px;
      color: rgba(255, 255, 255, 0.55);
    }

    /* ── TAB SWITCHER ──────────────────────────────────────── */
    .tab-switcher {
      display: flex;
      border: 0.5px solid rgba(255, 255, 255, 0.25);
      border-radius: 8px;
      overflow: hidden;
    }

    .tab-btn {
      padding: 5px 18px;
      font-size: 12px;
      background: transparent;
      border: none;
      color: rgba(255, 255, 255, 0.65);
      cursor: pointer;
      transition: background 0.15s;
    }

    .tab-btn.active {
      background: rgba(255, 255, 255, 0.18);
      color: #fff;
    }

    /* ── ACTION BUTTONS ────────────────────────────────────── */
    .tab-actions {
      display: flex;
      gap: 6px;
      align-items: center;
    }

    .act-btn {
      padding: 5px 12px;
      font-size: 12px;
      border-radius: 8px;
      border: 0.5px solid rgba(255, 255, 255, 0.3);
      background: transparent;
      color: rgba(255, 255, 255, 0.85);
      cursor: pointer;
      transition: background 0.15s;
    }

    .act-btn:hover {
      background: rgba(255, 255, 255, 0.1);
    }

    .act-btn.primary {
      background: rgba(255, 255, 255, 0.15);
    }

    /* ── DOC AREA ──────────────────────────────────────────── */
    .doc-area {
      flex: 1;
      overflow-y: auto;
      padding: 16px 20px;
    }

    /* ── TAB PANELS ────────────────────────────────────────── */
    .tab-panel {
      display: none;
    }

    .tab-panel.active {
      display: block;
    }

    /* ── PREVIEW CARD (del main original) ──────────────────── */
    .preview-card {
      background: #fff;
      border-radius: 10px;
      border: 1px solid #e0e0e0;
      padding: 20px;
    }

    .preview-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 16px;
      padding-bottom: 14px;
      border-bottom: 1px solid #eee;
      flex-wrap: wrap;
      gap: 12px;
    }

    .ph-left {
      display: flex;
      gap: 12px;
      flex: 1;
      min-width: 200px;
    }

    .logo-box {
      width: 56px;
      height: 56px;
      background: #f5f5f5;
      border: 1px solid #ddd;
      border-radius: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 9px;
      color: #aaa;
      flex-shrink: 0;
    }

    .ph-info strong {
      font-size: 12px;
      font-weight: 600;
      color: #222;
      display: block;
      margin-bottom: 2px;
    }

    .ph-info p {
      font-size: 11px;
      color: #666;
      line-height: 1.7;
    }

    .ph-right {
      text-align: right;
    }

    .doc-num {
      font-size: 22px;
      font-weight: 600;
      color: #0f4c81;
    }

    .doc-meta {
      font-size: 11px;
      color: #888;
      margin-top: 2px;
    }

    .client-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3px 24px;
      margin-bottom: 16px;
    }

    @media (max-width: 520px) {
      .client-grid {
        grid-template-columns: 1fr;
      }
    }

    .cl {
      font-size: 11px;
      color: #555;
      display: flex;
      gap: 4px;
    }

    .cl span:first-child {
      font-weight: 600;
      color: #333;
      min-width: 72px;
      flex-shrink: 0;
    }

    .table-wrap {
      width: 100%;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }

    .items-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 11px;
      margin-bottom: 14px;
      min-width: 480px;
    }

    .items-table th {
      background: #0f4c81;
      color: #fff;
      padding: 7px 8px;
      text-align: left;
      font-weight: 500;
      white-space: nowrap;
    }

    .items-table td {
      padding: 6px 8px;
      border-bottom: 1px solid #eee;
      color: #333;
    }

    .items-table tr:nth-child(even) td {
      background: #f9f9f9;
    }

    .btn-eliminar {
      font-size: 10px;
      padding: 2px 6px;
      border: 1px solid #ddd;
      border-radius: 4px;
      background: #fff;
      cursor: pointer;
      color: #c62828;
    }

    .totals {
      display: flex;
      justify-content: flex-end;
      margin-top: 4px;
    }

    .totals-box {
      width: 220px;
    }

    @media (max-width: 520px) {
      .totals-box {
        width: 100%;
      }
    }

    .total-row {
      display: flex;
      justify-content: space-between;
      font-size: 11px;
      padding: 3px 0;
      color: #666;
    }

    .total-final {
      display: flex;
      justify-content: space-between;
      font-size: 13px;
      font-weight: 600;
      padding: 7px 10px;
      background: #e85d14;
      color: #fff;
      border-radius: 6px;
      margin-top: 5px;
    }

    .preview-footer {
      margin-top: 20px;
      padding-top: 12px;
      border-top: 1px solid #eee;
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 10px;
    }

    @media (max-width: 600px) {
      .preview-footer {
        grid-template-columns: 1fr;
      }
    }

    .preview-footer strong {
      font-size: 10px;
      color: #555;
      font-weight: 600;
      display: block;
      margin-bottom: 2px;
    }

    .preview-footer p {
      font-size: 10px;
      color: #888;
    }

    .guia-header {
      background: #1a3a5c;
      color: #fff;
      padding: 8px 12px;
      border-radius: 6px;
      display: flex;
      justify-content: space-between;
      font-size: 11px;
      margin-bottom: 14px;
      flex-wrap: wrap;
      gap: 6px;
    }

    .badge-ok {
      background: #e8f5e9;
      color: #2e7d32;
    }

    .badge-warn {
      background: #fff8e1;
      color: #f57f17;
    }

    /* ══════════════════════════════════════════════════════════
         RESPONSIVE MOBILE (<768px)
      ══════════════════════════════════════════════════════════ */
    @media (max-width: 767px) {
      body {
        height: auto;
      }

      .global-topbar {
        padding: 0 12px;
        height: 44px;
      }

      .global-topbar .brand {
        font-size: 12px;
      }

      .global-topbar .brand span {
        display: none;
      }

      /* Layout stack vertical */
      .layout {
        flex-direction: column;
        overflow: visible;
      }

      /* Sidebar abajo, full width */
      .sidebar {
        width: 100%;
        min-width: unset;
        border-right: none;
        border-top: 0.5px solid #e0ddd4;
        order: 2;
        max-height: 40vh;
      }

      .sidebar-header {
        padding: 10px 12px 8px;
      }

      .sidebar-header p {
        font-size: 10px;
        margin-bottom: 6px;
      }

      .search-box {
        font-size: 11px;
        padding: 5px 8px;
      }

      .orders-list {
        padding: 6px;
        gap: 4px;
      }

      .order-card {
        padding: 8px 10px;
      }

      .order-id {
        font-size: 12px;
        margin-bottom: 2px;
      }

      .order-meta {
        font-size: 10px;
      }

      /* Main arriba, full width */
      .main {
        order: 1;
        flex: 1;
        overflow: visible;
      }

      .doc-topbar {
        padding: 0 12px;
        height: auto;
        min-height: 44px;
        flex-wrap: wrap;
        gap: 8px;
        padding-top: 8px;
        padding-bottom: 8px;
      }

      .doc-info {
        width: 100%;
        order: 1;
      }

      .doc-info .doc-code {
        font-size: 12px;
      }

      .doc-info .doc-date {
        font-size: 10px;
      }

      .tab-switcher {
        border: none;
        gap: 0;
        order: 3;
        width: 100%;
      }

      .tab-btn {
        flex: 1;
        padding: 6px 10px;
        font-size: 11px;
        border-bottom: 2px solid transparent;
        border-radius: 0;
      }

      .tab-btn.active {
        background: transparent;
        border-bottom-color: #fff;
        color: #fff;
      }

      .tab-actions {
        width: 100%;
        gap: 4px;
        order: 4;
      }

      .act-btn {
        flex: 1;
        padding: 4px 8px;
        font-size: 10px;
      }

      .doc-area {
        padding: 12px;
        overflow-y: auto;
      }

      /* Preview card */
      .preview-card {
        padding: 14px;
        border-radius: 6px;
      }

      .preview-header {
        flex-direction: column;
        margin-bottom: 12px;
        padding-bottom: 10px;
        gap: 10px;
      }

      .ph-left {
        gap: 10px;
        min-width: unset;
      }

      .logo-box {
        width: 48px;
        height: 48px;
        font-size: 8px;
      }

      .ph-info strong {
        font-size: 11px;
      }

      .ph-info p {
        font-size: 10px;
        line-height: 1.5;
      }

      .ph-right {
        width: 100%;
        text-align: left;
      }

      .doc-num {
        font-size: 18px;
      }

      .doc-meta {
        font-size: 10px;
        margin-top: 1px;
      }

      .client-grid {
        grid-template-columns: 1fr;
        gap: 2px 12px;
        margin-bottom: 12px;
      }

      .cl {
        font-size: 10px;
        gap: 3px;
      }

      .cl span:first-child {
        min-width: 60px;
      }

      .table-wrap {
        overflow-x: auto;
        margin-bottom: 10px;
      }

      .items-table {
        font-size: 10px;
        min-width: 100%;
      }

      .items-table th {
        padding: 5px 6px;
        font-size: 9px;
      }

      .items-table td {
        padding: 5px 6px;
        font-size: 10px;
      }

      .btn-eliminar,
      .btn-editar-producto {
        padding: 2px 4px;
        font-size: 9px;
      }

      .totals {
        margin-top: 8px;
      }

      .totals-box {
        width: 100%;
        max-width: 180px;
      }

      .total-row {
        padding: 2px 0;
        font-size: 10px;
      }

      .total-final {
        padding: 6px 8px;
        font-size: 12px;
        margin-top: 4px;
      }

      .preview-footer {
        margin-top: 14px;
        padding-top: 10px;
        grid-template-columns: 1fr;
        gap: 8px;
      }

      .preview-footer strong {
        font-size: 9px;
        margin-bottom: 1px;
      }

      .preview-footer p {
        font-size: 9px;
        line-height: 1.4;
      }

      .guia-header {
        padding: 6px 10px;
        font-size: 10px;
        margin-bottom: 10px;
        flex-wrap: wrap;
        gap: 4px;
      }

      .guia-header span {
        display: block;
        width: 100%;
        font-size: 9px;
      }
    }

    /* ══════════════════════════════════════════════════════════
         TABLET (768px - 1024px)
      ══════════════════════════════════════════════════════════ */
    @media (min-width: 768px) and (max-width: 1024px) {
      .sidebar {
        width: 200px;
        min-width: 200px;
      }

      .client-grid {
        grid-template-columns: 1fr;
      }

      .preview-footer {
        grid-template-columns: 1fr 1fr;
      }

      .doc-area {
        padding: 12px 16px;
      }

      .preview-card {
        padding: 16px;
      }
    }

    .doc-info {
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .doc-info .doc-code {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    /* ── COLUMNA COMANDOS ── */
    .cmd-cell {
      display: flex;
      align-items: center;
      gap: 6px;
      white-space: nowrap;
    }

    .cmd-btn {
      width: 28px;
      height: 28px;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 14px;
      flex-shrink: 0;
      transition: opacity 0.15s, transform 0.1s;
    }

    .cmd-btn:hover {
      opacity: 0.85;
      transform: scale(1.05);
    }

    .cmd-btn:active {
      transform: scale(0.95);
    }

    .cmd-btn-delete {
      background: #dc2626;
      color: #fff;
    }

    .cmd-btn-approve {
      background: #16a34a;
      color: #fff;
    }

    .cmd-input-qty {
      width: 64px;
      height: 28px;
      border: 1px solid #d1d5db;
      border-radius: 6px;
      text-align: center;
      font-size: 13px;
      font-weight: 600;
      outline: none;
      transition: border-color 0.2s;
      -moz-appearance: textfield;
    }

    .cmd-input-qty:focus {
      border-color: #1a56db;
    }

    .cmd-input-qty::-webkit-inner-spin-button,
    .cmd-input-qty::-webkit-outer-spin-button {
      opacity: 1;
      height: 28px;
    }

    .cmd-input-text {
      width: 120px;
      height: 14px;
      border: 1px solid #d1d5db;
      border-radius: 6px;
      padding: 0 8px;
      font-size: 13px;
      outline: none;
      transition: border-color 0.2s;
      color: #111827;
      background: #fff;
    }

    .cmd-input-text:focus {
      border-color: #1a56db;
      box-shadow: 0 0 0 2px rgba(26, 86, 219, 0.1);
    }

    .cmd-input-text::placeholder {
      color: #9ca3af;
    }

  

  </style>
</head>

