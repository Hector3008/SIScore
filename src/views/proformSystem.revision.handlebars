      }

      const proforms = await getProforms();
      printCards(proforms);
      ioToEmit(proforms)
      toastSuccess("proforma cerrada")
      cleanAll()
      
    }

  function comprimirImagen(file, maxWidth = 800, calidad = 0.6) {
    return new Promise((resolve) => {
      const reader = new FileReader()
      reader.onload = (e) => {
        const img = new Image()
        img.onload = () => {
          const canvas = document.createElement('canvas')
          let width = img.width
          let height = img.height
          if (width > maxWidth) {
            height = (height * maxWidth) / width
            width = maxWidth
          }
          canvas.width = width
          canvas.height = height
          canvas.getContext('2d').drawImage(img, 0, 0, width, height)
          resolve(canvas.toDataURL('image/jpeg', calidad))
        }
        img.src = e.target.result
      }
      reader.readAsDataURL(file)
    })
  }

    document.getElementById('cargar_foto').addEventListener('click', (e) => {
  e.stopPropagation()

  const anterior = document.getElementById('inputFotoGaleriaRevision')
  if (anterior) anterior.remove()

  const input = document.createElement('input')
  input.type = 'file'
  input.accept = 'image/*'
  input.id = 'inputFotoGaleriaRevision'
  input.style.display = 'none'
  document.body.appendChild(input)

  input.addEventListener('change', async (e) => {
    const file = e.target.files[0]
    if (!file) return
    const base64 = await comprimirImagen(file, 800, 0.6)
    currentPictures.push(base64)
    toastSuccess(`Foto agregada (${currentPictures.length} en total)`)
    e.target.value = ""

    currentProform.revision = currentPictures
    console.log("currentProform: ", currentProform)
    try {
      await fetch(`/api/proforms/${currentProform.code}`, {
        method: 'PUT',
        body: JSON.stringify(currentProform),
        headers: { 'Content-Type': 'application/json' },
      });
    } catch (error) {
      console.error('Error:', error);
    }
  })


  input.click()
})

