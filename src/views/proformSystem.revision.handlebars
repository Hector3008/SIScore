  async function printGuia(products) {
        products = products.filter(prod => {
      return prod.status == true
    })
    console.log("currentProform: ", currentProform)
    tables.guia.innerHTML = ""

    for (let [i, product] of products.entries()) {
        if (product.status == false) continue
      const productIndex = product.index
      const cantidad = product.cantidad

      for (let [j, option] of product.options.filter(o => o.status === true || o.status === "true").entries()) {

        // 👇 Índice REAL en el array sin filtrar
        const optionIndex = product.options.findIndex(o => o === option)

        const tr = document.createElement("tr")
        tr.classList.add(`guia_opcion_${product.index}`)
        tr.innerHTML = `
        <td>${j == 0 ? `<input type="checkbox" ${product.isChecked ? "checked" : ""}>` : ""}</td>
<td>${j == 0 ? String(i + 1).padStart(3, "0") : ""}</td>
        <td>${j == 0 ? product.cantidad : ""}</td>
        <td>${j == 0 ? `S/ ${product.monto}` : ""}</td>
        <td>${j == 0 ? product.nombre : ""}</td>
        <td>${j == 0 ? product.comentario : ""}</td>
        <td>
          <div class="cmd-cell">
            <button class="cmd-btn cmd-btn-delete">✕</button>
            <input class="cmd-input-qty" type="number" min="0" value="${option.CANTIDAD || 0}"/>
            <button class="cmd-btn cmd-btn-approve">✓</button>
          </div>
        </td>
        <td>${option.CODIGO_FORMATEADO}</td>
        <td>${option.STOCK_LV}</td>
        <td>${option.STOCK_SJL}</td>
        <td>${option.DESCRIPCION} / ${option.FAMILIA} / ${option.SUBFAMILIA}</td>
        <td>${option.EQUIVALENTES_STOCK}</td>
        <td>${option.UBICACION}</td>
      `

        if (j === 0) {
          const checkbox = tr.querySelector("input[type='checkbox']")

          checkbox.addEventListener("change", async (e) => {
            const prodPos = currentProform.productos.findIndex(p => p.index === productIndex)
            if (prodPos !== -1) {
              currentProform.productos[prodPos].isChecked = e.target.checked

              try {
                await fetch(`/api/proforms/${currentProform.code}`, {
                  method: 'PUT',
                  body: JSON.stringify(currentProform),
                  headers: { 'Content-Type': 'application/json' },
                });
              } catch (error) {
                console.error('Error:', error);
              }
            }

            const filas = tables.guia.querySelectorAll(`.guia_opcion_${productIndex}`)
            filas.forEach(fila => fila.classList.toggle("fila-aprobada", e.target.checked))

            const ultimaFila = [...filas][filas.length - 1]
            ultimaFila.style.display = e.target.checked ? "none" : ""
          })
        }

        tr.querySelector(".cmd-btn-delete").addEventListener("click", async () => {
          const prodArr = currentProform.productos
          const prodPos = prodArr.findIndex(p => p.index === productIndex)
          if (prodPos === -1) return

          if (prodArr[prodPos].options.filter(o => o.status === true || o.status === "true").length === 1) {
            const confirmar = confirm("Si eliminas esta opción desaparece todo el elemento pedido. ¿Deseas continuar?")
            if (!confirmar) return
          }

          // Cambiar status a false en lugar de eliminar
          prodArr[prodPos].options[optionIndex].status = false

          // Si todas las options están en false, marcar el producto como inactivo
          if (prodArr[prodPos].options.every(o => o.status === false || o.status === "false")) {
            prodArr[prodPos].status = false
          }

          try {
            await fetch(`/api/proforms/${currentProform.code}`, {
              method: 'PUT',
              body: JSON.stringify(currentProform),
              headers: { 'Content-Type': 'application/json' },
            });
          } catch (error) {
            console.error('Error:', error);
          }

          printGuia(currentProform.productos)
        })

        tr.querySelector(".cmd-btn-approve").addEventListener("click", async () => {
          const prodPos = currentProform.productos.findIndex(p => p.index === productIndex)
          if (prodPos !== -1) {
            const input = tr.querySelector(".cmd-input-qty")
            input.value = cantidad

            currentProform.productos[prodPos].options[optionIndex].CANTIDAD = Number(cantidad)

            try {
              await fetch(`/api/proforms/${currentProform.code}`, {
                method: 'PUT',
                body: JSON.stringify(currentProform),
                headers: { 'Content-Type': 'application/json' },
              });
            } catch (error) {
              console.error('Error:', error);
            }
          }
        })

        tr.querySelector(".cmd-input-qty").addEventListener("change", async (e) => {
          const prodPos = currentProform.productos.findIndex(p => p.index === productIndex)
          if (prodPos !== -1) {
            currentProform.productos[prodPos].options[optionIndex].CANTIDAD = Number(e.target.value)

            try {
              await fetch(`/api/proforms/${currentProform.code}`, {
                method: 'PUT',
                body: JSON.stringify(currentProform),
                headers: { 'Content-Type': 'application/json' },
              });
            } catch (error) {
              console.error('Error:', error);
            }
          }
        })

        tables.guia.appendChild(tr)
      }

      // Fila de "otra opción"
      const tr2 = document.createElement("tr")
      tr2.classList.add(`guia_opcion_${product.index}`)
      tr2.innerHTML = `
      <td></td><td></td><td></td><td></td><td></td><td></td>
      <td>
        <div class="cmd-cell">
          <button class="cmd-btn cmd-btn-delete">✕</button>
          <input class="cmd-input-qty" type="number" min="0" value="0"/>
          <button class="cmd-btn cmd-btn-approve">✓</button>
        </div>
      </td>
      <td><input class="cmd-input-text" type="text" placeholder="Otra opcion..."/></td>
      <td>➕</td>
      <td></td><td></td><td></td><td></td>
    `

      tr2.querySelector(".cmd-btn-approve").addEventListener("click", () => {
        const input = tr2.querySelector(".cmd-input-qty")
        input.value = cantidad
      })

      tr2.querySelector("td:nth-child(9)").addEventListener("click", async () => {
        const inputText = tr2.querySelector(".cmd-input-text")
        const codigo = inputText.value.trim()

        if (!codigo) {
          alert("Escribe un código antes de agregar.")
          return
        }

        const nuevaOpcion = {
          CODIGO: codigo,
          CODIGO_FORMATEADO: codigo,
          DESCRIPCION: "",
          EQUIVALENTES_STOCK: "",
          FAMILIA: "",
          ID: "pending",
          MARCA: "",
          PROVEEDOR: "",
          STOCK: 0,
          STOCK_LV: 0,
          STOCK_SJL: 0,
          SUBFAMILIA: "",
          UBICACION: "pending",
          status: "true"
        }

        const prodPos = currentProform.productos.findIndex(p => p.index === productIndex)
        if (prodPos === -1) return

        currentProform.productos[prodPos].options.push(nuevaOpcion)

        try {
          await fetch(`/api/proforms/${currentProform.code}`, {
            method: 'PUT',
            body: JSON.stringify(currentProform),
            headers: { 'Content-Type': 'application/json' },
          });
        } catch (error) {
          console.error('Error:', error);
        }

        printGuia(currentProform.productos)
      })

      tables.guia.appendChild(tr2)

      // Aplicar estado inicial según isChecked
      if (product.isChecked) {
        tables.guia.querySelectorAll(`.guia_opcion_${productIndex}`)
          .forEach(fila => fila.classList.add("fila-aprobada"))

        tr2.style.display = "none"
      }
    }
  }
