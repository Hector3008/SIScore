    async function getProforms() {
      try {
        const response = await fetch('/api/proforms');
        const data = await response.json();
        return data.payload;
      } catch (err) {
        console.error(err);
        return null;
      }
    }

    function ioToEmit(data) {
      socket.emit("updatedProforms", data);
    }
    let activeToast;
    function toastSuccess(msg) {
      if (activeToast) activeToast.remove();

      const toast = document.createElement("div");
      activeToast = toast;

      toast.textContent = msg;
      toast.style.cssText = `
    position: fixed;
    top: 20px;
    left: 20px;
    background: #27ae60;
    color: white;
    padding: 10px 15px;
    border-radius: 6px;
    z-index: 9999;
    font-size: 14px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.2);
    opacity: 0;
    transform: translateY(10px);
    transition: all 0.3s ease;
  `;

      document.body.appendChild(toast);

      // animación entrada
      setTimeout(() => {
        toast.style.opacity = "1";
        toast.style.transform = "translateY(0)";
      }, 10);

      // salida
      setTimeout(() => {
        toast.style.opacity = "0";
        toast.style.transform = "translateY(10px)";

        setTimeout(() => {
          toast.remove();
          activeToast = null;
        }, 300);
      }, 2500);
    }

    async function bloquear() {

      currentProform.isLocked = true

      const res = await fetch(`/api/proforms/${currentProform.code}`).then(res => res.json());
      const order = res.payload.payload.doc;
      order.isLocked = true

      try {
        await fetch(`/api/proforms/${currentProform.code}`, {
          method: 'PUT',
          body: JSON.stringify(order),
          headers: { 'Content-Type': 'application/json' },
        });
      } catch (error) {
        console.error('Error:', error);
      }

      const proforms = await getProforms();
      printCards(proforms);
      ioToEmit(proforms)
      toastSuccess("proforma bloqueada")
    }

    async function aprobar() {

      if (!currentProform.code) return toastError("selecciona una orden")

      currentProform.tipo = "cerrada"

      const res = await fetch(`/api/proforms/${currentProform.code}`).then(res => res.json());
      const order = res.payload.payload.doc;
      order.isLocked = true
      order.tipo = "cerrada"
      try {
        await fetch(`/api/proforms/${currentProform.code}`, {
          method: 'PUT',
          body: JSON.stringify(order),
          headers: { 'Content-Type': 'application/json' },
        });
      } catch (error) {
