  document.querySelector("#dl_proforma_desktop").addEventListener("change", (e) => {
    if (!e.target.checked) return;
    generarPDFProforma(currentProform);
    e.target.checked = false;
  });

  document.querySelector("#dl_guia_desktop").addEventListener("change", (e) => {
    if (!e.target.checked) return;
    generarPDFGuia(currentProform);
    e.target.checked = false;
  });
</script>
</body>

