  async function actualizarProforma() {

  const res = await fetch(`/api/proforms/${currentProform.code}`);
  if (!res.ok) {throw new Error("Proforma no encontrada");
  }
  const lastVersion = await res.json();

  const lastVersionPayload = lastVersion.payload.payload

  const lastVersionDoc = lastVersion.payload.payload.doc

  const versiones_lastVersion = lastVersionDoc.versiones

  const { versiones, ...lastVersionSinVersiones } = lastVersionDoc;

    lastVersionPayload.doc = lastVersionSinVersiones
      versiones_lastVersion.push(lastVersionPayload)

    currentProform.versiones = versiones_lastVersion
    currentProform.version = currentProform.version+1
 
    try {

      const res = await fetch(`/api/proforms/${currentProform.code}`, {
        method: "put",
        body: JSON.stringify(currentProform),
        headers: {
          "Content-Type": "application/json",
        },
      });
      const data = await res.json();
      cleanAll()
    } catch (err) {
      console.error(err);
      toastError("error al actualizar la proforma");
    }
  }
  
