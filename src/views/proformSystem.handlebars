    function printProformas(proformas) {
      tables.proformas.innerHTML = ""
      for (let proform of proformas) {
        let tipo

        switch (proform.payload.doc.tipo) {
          case "Borrador":
            tipo = "borrador"

            break;
          case "cotizacion":
            tipo = "cotizacion"
            break;
          case "orden_salida":
            tipo = "orden-salida"
            break;
          default: "undefined"
        }
        let tr = document.createElement("tr")
        tr.id = `${proform.payload.doc.code}_tr`
        tr.innerHTML = `
    <td><span class="doc-tag">${proform.payload.doc.code}</span></td>
    
              <td>${proform.payload.doc.vendedor}</td>
              <td><span class="tipo-tag tipo-${tipo}">${proform.payload.doc.tipo}</span></td>
              <td><span class="activo-tag activo-${proform.payload.doc.status == true ? "si" : "no"}">${proform.payload.doc.status == true ? "Sí" : "No"}</span></td>
              <td><button id="traer_proforma_${proform.payload.doc.code}" class="btn-cargar-proforma">Cargar</button></td>
    `
        tables.proformas.appendChild(tr)
      }
    }
    printProformas(proforms)
    
