<!DOCTYPE html>
<html lang="es">

<head>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.2/jspdf.plugin.autotable.min.js"></script>


  <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>

  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Proformas</title>
  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html,
    body {
      height: 100%;
      font-family: sans-serif;
    }

    #tipo {
      background: transparent;
      color: #d0d5e0;
      font-size: 11px;
      font-weight: 500;
      padding: 4px 8px;
      border-radius: 4px;
      border: 1px solid #5a6070;
      outline: none;
      appearance: none;
      cursor: pointer;
      flex-shrink: 0;
    }

    #tipo option {
      background: #1a1f2e;
      color: #d0d5e0;
    }

    #tipo:focus {
      border-color: #8892a4;
    }

    /* ══════════════════════════════════════
       DESKTOP (≥900px) — layout fijo en pantalla
    ══════════════════════════════════════ */
    @media (min-width: 900px) {
      body {
        overflow: hidden;
      }

      .topbar-row1 {
        display: flex;
        align-items: center;
        gap: 10px;
        flex: 0 1 auto;
        /* ← importante */
        min-width: 0;
      }

      .page {
        display: flex;
        flex-direction: column;
        height: 100vh;
      }

      /* Topbar una sola fila */
      .topbar {
        height: 40px;
        flex-wrap: nowrap;

      }

      .topbar-row2 {
        display: none;
      }

      .topbar-actions {
        display: contents;
      }

      /* Subheader en grid 2 col */
      .subheader {
        flex-shrink: 0;
        display: grid;
        grid-template-columns: 300px 1fr;
        border-bottom: 1px solid #ddd;
        background: #fff;
      }

      .sidebar-label {
        display: flex;
      }

      /* Body en grid 2 col con scroll independiente */
      .body-area {
        flex: 1;
        min-height: 0;
        display: grid;
        grid-template-columns: 300px 1fr;
      }

      .sidebar {
        overflow-y: auto;
        overflow-x: hidden;
      }

      .main {
        overflow-y: auto;
        overflow-x: hidden;
      }
    }

    /* ══════════════════════════════════════
       MOBILE/TABLET (<900px) — columna única, scroll global
    ══════════════════════════════════════ */
    @media (max-width: 899px) {
      body {
        overflow-y: auto;
      }

      .page {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
      }

      /* Topbar en 2 filas */
      .topbar {
        height: auto;
        flex-wrap: wrap;
        padding: 8px 12px;
        gap: 6px;
      }

      .topbar-row1 {
        display: flex;
        align-items: center;
        gap: 8px;
        width: 100%;
        min-width: 0;
        /* ← permite que los hijos se encojan */
      }


      @media (min-width: 900px) {
        .topbar-actions {
          display: flex;
          align-items: center;
          gap: 8px;
          margin-left: auto;
          /* ← empuja acciones a la derecha */
        }
      }

      .topbar-row2 {
        display: flex;
        align-items: center;
        gap: 6px;
        width: 100%;
        padding-top: 6px;
        border-top: 1px solid #333a4d;
        flex-wrap: wrap;
      }

      .topbar-actions {
        display: contents;
      }

      /* Subheader: ocultar label, tabs full width */
      .subheader {
        display: block;
        border-bottom: 1px solid #ddd;
        background: #fff;
      }

      .sidebar-label {
        display: none;
      }

      .tab-bar {
        height: 40px;
      }

      /* Body: columna única */
      .body-area {
        display: flex;
        flex-direction: column;
        flex: 1;
      }

      .sidebar {
        overflow: visible;
        border-right: none;
        border-bottom: 1px solid #ddd;
      }

      .main {
        overflow: visible;
        padding: 12px;
      }
    }

    /* ══════════════════════════════════════
       ESTILOS COMPARTIDOS
    ══════════════════════════════════════ */

    /* Topbar */
    .topbar {
      flex-shrink: 0;
      background: #1a1f2e;
      border-bottom: 1px solid #333a4d;
      padding: 0 14px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .logo-pill {
      background: #0f4c81;
      color: #fff;
      font-size: 11px;
      font-weight: 500;
      padding: 5px 10px;
      border-radius: 4px;
      white-space: nowrap;
      flex-shrink: 0;
    }

    .doc-block {
      flex-shrink: 0;
    }

    .doc-id {
      font-size: 16px;
      font-weight: 500;
      color: #e8eaf0;
      line-height: 1.1;
    }

    .doc-date {
      font-size: 10px;
      color: #8892a4;
    }

    .divider-v {
      width: 1px;
      height: 20px;
      background: #3a4155;
      flex-shrink: 0;
      margin: 0 2px;
    }

    .topbar .btn {
      font-size: 11px;
      padding: 5px 11px;
      border-radius: 5px;
      cursor: pointer;
      border: 1px solid #5a6070;
      background: transparent;
      color: #d0d5e0;
      flex-shrink: 0;
      white-space: nowrap;
    }

    .group {
      display: flex;
      align-items: center;
      gap: 6px;
      flex-shrink: 0;
    }

    .group-label {
      font-size: 11px;
      color: #d0d5e0;
      white-space: nowrap;
      flex-shrink: 0;
    }

    .checks-col {
      display: flex;
      flex-direction: column;
      gap: 3px;
    }

    .check-opt {
      display: flex;
      align-items: center;
      gap: 4px;
      font-size: 10px;
      color: #8892a4;
      cursor: pointer;
      white-space: nowrap;
    }

    .check-opt input[type="checkbox"] {
      width: 11px;
      height: 11px;
      accent-color: #0f4c81;
      flex-shrink: 0;
    }

    /* Subheader */
    .sidebar-label {
      padding: 8px 14px;
      font-size: 10px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: .6px;
      color: #888;
      border-right: 1px solid #ddd;
      align-items: center;
    }

    .tab-bar {
      display: flex;
    }

    .tab {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 11px;
      font-weight: 500;
      cursor: pointer;
      color: #666;
      border-right: 1px solid #ddd;
      height: 36px;
    }

    .tab:last-child {
      border-right: none;
    }

    .tab.active {
      background: #0f4c81;
      color: #fff;
    }

    /* Sidebar */
    .sidebar {
      background: #fff;
    }

    .section {
      border-bottom: 1px solid #eee;
    }

    .section-header {
      padding: 10px 14px;
      font-size: 10px;
      font-weight: 600;
      color: #666;
      text-transform: uppercase;
      letter-spacing: .6px;
      background: #f7f7f7;
      display: flex;
      align-items: center;
      justify-content: space-between;
      cursor: pointer;
      user-select: none;
    }

    .section-body {
      padding: 10px 14px;
      display: flex;
      flex-direction: column;
      gap: 7px;
    }

    .field-group {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 5px;
    }

    .field-full {
      grid-column: 1 / -1;
    }

    .sidebar input[type="text"],
    .sidebar input[type="number"],
    .sidebar input[type="date"],
    .sidebar select {
      height: 30px;
      border: 1px solid #ddd;
      border-radius: 5px;
      background: #f9f9f9;
      padding: 0 8px;
      font-size: 11px;
      color: #333;
      width: 100%;
      outline: none;
      -webkit-appearance: none;
      appearance: none;
    }

    .sidebar input:focus,
    .sidebar select:focus {
      border-color: #0f4c81;
      background: #fff;
    }

    .btn-row {
      display: flex;
      gap: 5px;
      flex-wrap: wrap;
    }

    .btn-sm {
      font-size: 11px;
      padding: 6px 12px;
      border-radius: 5px;
      cursor: pointer;
      border: none;
      color: #fff;
      font-weight: 500;
    }

    .btn-sm-green {
      background: #2e7d32;
    }

    .btn-sm-blue {
      background: #1565c0;
    }

    .btn-sm-orange {
      background: #e85d14;
    }

    .btn-sm-red {
      background: #c62828;
    }

    .total-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 2px 0;
    }

    .total-item span:first-child {
      font-size: 11px;
      color: #888;
    }

    .total-item span:last-child {
      font-size: 13px;
      font-weight: 600;
      color: #222;
    }

    .stock-table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 2px;
      table-layout: fixed;
      /* ← clave: fuerza que las columnas respeten el ancho */
    }

    .stock-table td {
      position: relative;
      font-size: 10px;
      padding: 4px 4px;
      border-bottom: 1px solid #f0f0f0;
      color: #555;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      /* ← corta el texto largo con ... */
      vertical-align: top;
    }

    .stock-table tr:last-child td {
      border-bottom: none;
    }

    .stock-table td[title]:hover::after {
      content: attr(title);
      position: absolute;
      left: 0;
      top: 100%;
      z-index: 99;
      background: #1a1f2e;
      color: #fff;
      font-size: 10px;
      padding: 5px 8px;
      border-radius: 4px;
      white-space: normal;
      width: 220px;
      line-height: 1.4;
      pointer-events: none;
      box-shadow: 0 2px 6px rgba(0, 0, 0, 0.25);
    }

    /* Columna 1: código + descripción — ocupa la mayor parte */
    .stock-table td:nth-child(1) {
      width: 55%;
    }

    /* Columna 2: stock LV/SJL */
    .stock-table td:nth-child(2) {
      width: 20%;
      text-align: right;
    }

    /* Columna 3: equivalentes */
    .stock-table td:nth-child(3) {
      width: 25%;
      text-align: right;
    }

    .badge {
      display: inline-block;
      padding: 2px 7px;
      border-radius: 10px;
      font-size: 9px;
      font-weight: 500;
    }

    .btn-agregar-row {
      width: 22px;
      height: 22px;
      border-radius: 50%;
      border: 1px solid #1565c0;
      background: transparent;
      color: #1565c0;
      font-size: 14px;
      line-height: 1;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0;
      flex-shrink: 0;
    }

    .btn-agregar-row:hover {
      background: #1565c0;
      color: #fff;
    }

    .btn-ver-row {
      width: 22px;
      height: 22px;
      border-radius: 50%;
      border: 1px solid #888;
      background: transparent;
      color: #888;
      font-size: 12px;
      line-height: 1;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0;
      flex-shrink: 0;
    }

    .btn-ver-row:hover {
      border-color: #1a1f2e;
      color: #1a1f2e;
    }

    .stock-table td:nth-child(1) {
      width: 55%;
      white-space: normal;
      line-height: 1.4;
    }

    .badge-ok {
      background: #e8f5e9;
      color: #2e7d32;
    }

    .badge-warn {
      background: #fff8e1;
      color: #f57f17;
    }

    /* Main / Preview */
    .main {
      background: #f0f2f5;
      padding: 16px;
    }

    .tab-content {
      display: none;
    }

    .tab-content.active {
      display: block;
    }

    .preview-card {
      background: #fff;
      border-radius: 10px;
      border: 1px solid #e0e0e0;
      padding: 20px;
    }

    .preview-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 16px;
      padding-bottom: 14px;
      border-bottom: 1px solid #eee;
      flex-wrap: wrap;
      gap: 12px;
    }

    .ph-left {
      display: flex;
      gap: 12px;
      flex: 1;
      min-width: 200px;
    }

    .logo-box {
      width: 56px;
      height: 56px;
      background: #f5f5f5;
      border: 1px solid #ddd;
      border-radius: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 9px;
      color: #aaa;
      flex-shrink: 0;
    }

    .ph-info strong {
      font-size: 12px;
      font-weight: 600;
      color: #222;
      display: block;
      margin-bottom: 2px;
    }

    .ph-info p {
      font-size: 11px;
      color: #666;
      line-height: 1.7;
    }

    .ph-right {
      text-align: right;
    }

    .doc-num {
      font-size: 22px;
      font-weight: 600;
      color: #0f4c81;
    }

    .doc-meta {
      font-size: 11px;
      color: #888;
      margin-top: 2px;
    }

    .client-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3px 24px;
      margin-bottom: 16px;
    }

    @media (max-width: 520px) {
      .client-grid {
        grid-template-columns: 1fr;
      }
    }

    .cl {
      font-size: 11px;
      color: #555;
      display: flex;
      gap: 4px;
    }

    .cl span:first-child {
      font-weight: 600;
      color: #333;
      min-width: 72px;
      flex-shrink: 0;
    }

    /* Tabla items — scroll horizontal en mobile */
    .table-wrap {
      width: 100%;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }

    .items-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 11px;
      margin-bottom: 14px;
      min-width: 480px;
    }

    .items-table th {
      background: #0f4c81;
      color: #fff;
      padding: 7px 8px;
      text-align: left;
      font-weight: 500;
      white-space: nowrap;
    }

    .items-table td {
      padding: 6px 8px;
      border-bottom: 1px solid #eee;
      color: #333;
    }

    .items-table tr:nth-child(even) td {
      background: #f9f9f9;
    }

    .btn-eliminar {
      font-size: 10px;
      padding: 2px 6px;
      border: 1px solid #ddd;
      border-radius: 4px;
      background: #fff;
      cursor: pointer;
      color: #c62828;
    }

    .totals {
      display: flex;
      justify-content: flex-end;
      margin-top: 4px;
    }

    .totals-box {
      width: 220px;
    }

    @media (max-width: 520px) {
      .totals-box {
        width: 100%;
      }
    }

    .total-row {
      display: flex;
      justify-content: space-between;
      font-size: 11px;
      padding: 3px 0;
      color: #666;
    }

    .total-final {
      display: flex;
      justify-content: space-between;
      font-size: 13px;
      font-weight: 600;
      padding: 7px 10px;
      background: #e85d14;
      color: #fff;
      border-radius: 6px;
      margin-top: 5px;
    }

    .preview-footer {
      margin-top: 20px;
      padding-top: 12px;
      border-top: 1px solid #eee;
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 10px;
    }

    @media (max-width: 600px) {
      .preview-footer {
        grid-template-columns: 1fr;
      }
    }

    .preview-footer strong {
      font-size: 10px;
      color: #555;
      font-weight: 600;
      display: block;
      margin-bottom: 2px;
    }

    .preview-footer p {
      font-size: 10px;
      color: #888;
    }

    .guia-header {
      background: #1a3a5c;
      color: #fff;
      padding: 8px 12px;
      border-radius: 6px;
      display: flex;
      justify-content: space-between;
      font-size: 11px;
      margin-bottom: 14px;
      flex-wrap: wrap;
      gap: 6px;
    }

    #empresa_nombre {
      background: #0f4c81;
      color: #fff;
      font-size: 10px;
      font-weight: 500;
      padding: 4px 10px;
      border-radius: 4px;
      letter-spacing: .4px;
      border: none;
      outline: none;
      appearance: none;
      max-width: 160px;
      /* ← limita el ancho */
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      cursor: pointer;
    }

    .toast-overlay {
      display: none;
      position: fixed;
      inset: 0;
      z-index: 999;
      background: rgba(0, 0, 0, 0.3);
      align-items: flex-start;
      justify-content: flex-end;
      padding: 60px 16px 0 0;
    }

    .toast-overlay.open {
      display: flex;
    }

    .toast-box {
      background: #1a1f2e;
      border: 1px solid #3a4155;
      border-radius: 8px;
      width: 260px;
      overflow: hidden;
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.4);
      animation: slideDown 0.18s ease;
    }

    @keyframes slideDown {
      from {
        opacity: 0;
        transform: translateY(-10px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .toast-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 10px 14px;
      border-bottom: 1px solid #3a4155;
      font-size: 12px;
      font-weight: 500;
      color: #e8eaf0;
    }

    .toast-close {
      background: transparent;
      border: none;
      color: #8892a4;
      cursor: pointer;
      font-size: 13px;
      padding: 0;
      line-height: 1;
    }

    .toast-close:hover {
      color: #fff;
    }

    .toast-body {
      padding: 12px 14px;
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .toast-label {
      font-size: 10px;
      color: #8892a4;
      text-transform: uppercase;
      letter-spacing: .4px;
    }

    .toast-input {
      height: 30px;
      border: 1px solid #3a4155;
      border-radius: 5px;
      background: #0f1520;
      padding: 0 10px;
      font-size: 12px;
      color: #e8eaf0;
      outline: none;
      width: 100%;
    }

    .toast-input:focus {
      border-color: #0f4c81;
    }

    .toast-footer {
      display: flex;
      gap: 6px;
      padding: 0 14px 12px;
    }

    .toast-box-wide {
      width: 460px;
    }

    @media (max-width: 520px) {
      .toast-box-wide {
        width: calc(100vw - 24px);
      }
    }

    .toast-table-wrap {
      overflow-y: auto;
      max-height: 220px;
      margin: 0 14px;
      border: 1px solid #2a3040;
      border-radius: 6px;
    }

    .toast-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 11px;
    }

    .toast-table thead th {
      background: #0f1520;
      color: #8892a4;
      padding: 7px 10px;
      text-align: left;
      font-weight: 500;
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: .4px;
      position: sticky;
      top: 0;
      z-index: 1;
    }

    .toast-table tbody tr {
      border-bottom: 1px solid #2a3040;
      transition: background 0.1s;
    }

    .toast-table tbody tr:last-child {
      border-bottom: none;
    }

    .toast-table tbody tr:hover {
      background: #1e2535;
    }

    .toast-table td {
      padding: 7px 10px;
      color: #c8cdd8;
      vertical-align: middle;
    }

    .doc-tag {
      font-family: monospace;
      font-size: 11px;
      color: #7eb3f5;
      font-weight: 600;
    }

    .tipo-tag {
      display: inline-block;
      padding: 2px 7px;
      border-radius: 10px;
      font-size: 9px;
      font-weight: 500;
    }

    .tipo-borrador {
      background: #2a3040;
      color: #8892a4;
    }

    .tipo-cotizacion {
      background: #0d3060;
      color: #7eb3f5;
    }

    .tipo-orden-salida {
      background: #1a3a20;
      color: #6dbb7a;
    }

    .activo-tag {
      display: inline-block;
      padding: 2px 7px;
      border-radius: 10px;
      font-size: 9px;
      font-weight: 500;
    }

    .activo-si {
      background: #1a3a20;
      color: #6dbb7a;
    }

    .activo-no {
      background: #3a1a1a;
      color: #e07070;
    }

    .btn-cargar-proforma {
      font-size: 10px;
      padding: 3px 9px;
      border-radius: 4px;
      border: 1px solid #3a4155;
      background: transparent;
      color: #7eb3f5;
      cursor: pointer;
      white-space: nowrap;
    }

    .btn-cargar-proforma:hover {
      background: #0f4c81;
      border-color: #0f4c81;
      color: #fff;
    }

    .preview-overlay {
      display: none;
      position: fixed;
      inset: 0;
      z-index: 999;
      background: rgba(0, 0, 0, 0.35);
      align-items: center;
      justify-content: center;
      padding: 16px;
    }

    .preview-overlay.open {
      display: flex;
    }

    .preview-product-card {
