    function printCode() {
      const doc_num = [
        ...document.querySelectorAll(".doc-num"),
        ...document.querySelectorAll(".doc-id")
      ];
      async function getProforms() {
        try {
          const response = await fetch("/api/proforms");
          const data = await response.json();
          return data.payload;
        } catch (err) {
          console.error(err);
          return null;
        }
      }
      async function getProformNumber() {
        const proforms = await getProforms();
        return "DP-" + String(proforms.length + 1).padStart(7, "0");
      }
      let proformNumber;
      async function esNueva() {
        let proformNumber = await getProformNumber();
        for (let doc of doc_num) {
          if (!currentProform.esNueva) {
            document.querySelector("#es_nueva").textContent = ""
            doc.textContent = currentProform.code
          } else {
            doc.textContent = proformNumber;
            currentProform.code = proformNumber
            document.querySelector("#es_nueva").textContent = "[Nueva]"
          }
        }
      }
      esNueva();
    }
    printCode()
    //✅
    async function cargarProforma() {
      currentProform.esNueva = false;
      currentProform.status = true;

      const body = {
        payload: { doc: { ...currentProform } }
      };

      try {
        const res = await fetch("/api/proforms/", {
          method: "post",
          body: JSON.stringify(body),
          headers: {
            "Content-Type": "application/json",
          },
        });

        await res.text();

        cleanAll();      // 👈 ahora sí después
        await printCode(); // 👈 espera el nuevo código
toastSuccess("proforma cargada")
      } catch (err) {
        console.error(err);
      }
    }
    //✅
    function printTotal() {
      const suma = currentProform.productos.filter(p => p.status === true).reduce((acc, p) => acc + Number(p.total || 0), 0);

      let igv = 0

      proformPreview.total.textContent = "S/ " + suma.toFixed(2);
      if (currentProform.comprobante === "Boleta" || currentProform.comprobante === "Factura") { igv = suma * 0.18 }

      let subtotal = suma - igv
      proformPreview.igv.textContent = igv.toFixed(2)
      proformPreview.subtotal.textContent = subtotal.toFixed(2)

    }

