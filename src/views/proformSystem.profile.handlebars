    async function getProforms() {
      try {
        const response = await fetch('/api/proforms');
        const data = await response.json();
        return data.payload;
      } catch (err) {
        console.error(err);
        return null;
      }
    }

    socket.on('updatedProforms', (data) => {
      proformas = data
      printOrders(data);
    })
      ;


    async function verMás(code) {
      const res = await fetch(`/api/proforms/${code}`).then(res => res.json());
      const order = res.payload.payload.doc;
    }

    //btn ver más: 
    grid.orders.addEventListener('click', (e) => {
      if (e.target.classList.contains('btn-see')) {
        const btn = e.target.closest('.btn-see');
        if (btn) {
          const code = btn.dataset.code;
          abrirVistaGuia(code)
        }
      }
    });

    document.querySelector("#buscar_order").addEventListener("input", (e) => {
      const value = e.target.value;
      const tokens = value.toLowerCase().split(/\s+/).filter(Boolean);
      const orders = proformas
      const filtered = orders.filter(p => {
        const doc = p.payload.doc;
        const text = `
      ${doc.code}
      ${doc.cliente.nombre}
      ${doc.vendedor}
      ${doc.fecha}
    `.toLowerCase();

        return tokens.every(word => text.includes(word));
      });
      printOrders(filtered);
    });

    function switchView(name) {
      document.getElementById('view-proforma').style.display = name === 'proforma' ? 'block' : 'none';
      document.getElementById('view-guia').style.display = name === 'guia' ? 'block' : 'none';
      document.getElementById('view-revision').style.display = name === 'revision' ? 'block' : 'none';
      document.getElementById('view-relacionales').style.display = name === 'relacionales' ? 'block' : 'none';
      document.getElementById('view-imagenes').style.display = name === 'imagenes' ? 'block' : 'none';

      document.getElementById('sw-proforma').style.background = name === 'proforma' ? '#0f4c81' : 'transparent';
      document.getElementById('sw-proforma').style.color = name === 'proforma' ? '#fff' : '#8892a4';

      document.getElementById('sw-guia').style.background = name === 'guia' ? '#0f4c81' : 'transparent';
      document.getElementById('sw-guia').style.color = name === 'guia' ? '#fff' : '#8892a4';

      document.getElementById('sw-revision').style.background = name === 'revision' ? '#0f4c81' : 'transparent';
      document.getElementById('sw-revision').style.color = name === 'revision' ? '#fff' : '#8892a4';

      document.getElementById('sw-relacionales').style.background = name === 'relacionales' ? '#0f4c81' : 'transparent';
      document.getElementById('sw-relacionales').style.color = name === 'relacionales' ? '#fff' : '#8892a4';

      document.getElementById('sw-imagenes').style.background = name === 'imagenes' ? '#0f4c81' : 'transparent';
      document.getElementById('sw-imagenes').style.color = name === 'imagenes' ? '#fff' : '#8892a4';
    }

    function toastError(msg) {
      const toast = document.createElement("div");

      toast.textContent = msg;
      toast.style.position = "fixed";
      toast.style.top = "20px";
      toast.style.left = "20px";
      toast.style.background = "#e74c3c";
      toast.style.color = "#fff";
      toast.style.padding = "10px 15px";
      toast.style.borderRadius = "6px";
      toast.style.boxShadow = "0 2px 8px rgba(0,0,0,0.2)";
      toast.style.zIndex = "9999";
      toast.style.fontSize = "14px";

      document.body.appendChild(toast);

      setTimeout(() => {
        toast.remove();
      }, 3000);
    }
  

    
      const buttons = document.getElementsByClassName("btn-send");

