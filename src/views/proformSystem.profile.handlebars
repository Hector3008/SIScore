      color: #888;
    }

    .card-top {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 8px;
    }

    .badge-tipo {
      font-size: 12px;
      font-weight: 500;
      color: #555;
    }
  </style>
</head>

