<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Profile</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    :root {
      --navy: #0d1b3e;
      --blue: #1a56db;
      --blue-h: #1447c0;
      --green: #16a34a;
      --bg: #f3f4f6;
      --card: #ffffff;
      --border: #e5e7eb;
      --text: #111827;
      --muted: #6b7280;
      --badge-active-bg: #dbeafe;
      --badge-active-txt: #1d4ed8;
      --radius: 10px;
      --shadow: 0 1px 3px rgba(0, 0, 0, .08), 0 1px 2px rgba(0, 0, 0, .06);
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    .fila-aprobada {
      background-color: #d4edda !important;
    }

    .fila-aprobada td {
      background-color: #d4edda !important;
    }

    /* ── TOP NAV ── */
    .topnav {
      background: var(--navy);
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 20px;
      height: 56px;
      flex-shrink: 0;
      gap: 8px;
    }

    .topnav-left {
      display: flex;
      align-items: center;
      gap: 10px;
      flex-shrink: 0;
    }

    .hamburger {
      background: none;
      border: none;
      cursor: pointer;
      color: #fff;
      display: flex;
      flex-direction: column;
      gap: 4px;
      padding: 4px;
    }

    .hamburger span {
      display: block;
      width: 20px;
      height: 2px;
      background: #fff;
      border-radius: 2px;
    }

    .company-badge {
      background: var(--blue);
      color: #fff;
      font-weight: 600;
      font-size: 13px;
      padding: 6px 12px;
      border-radius: 6px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      max-width: 200px;
    }

    /* En móvil mostramos versión corta */
    .company-badge .full {
      display: inline;
    }

    .company-badge .short {
      display: none;
    }

    .topnav-center {
      color: #fff;
      text-align: center;
      flex: 1;
      min-width: 0;
    }

    .topnav-center .page-title {
      font-weight: 700;
      font-size: 15px;
      white-space: nowrap;
    }

    .topnav-center .page-sub {
      font-size: 12px;
      color: #93c5fd;
      white-space: nowrap;
    }

    .topnav-right {
      display: flex;
      align-items: center;
      gap: 10px;
      flex-shrink: 0;
    }

    .notif-btn {
      position: relative;
      background: none;
      border: none;
      cursor: pointer;
      color: #fff;
      font-size: 20px;
      padding: 4px;
    }

    .notif-badge {
      position: absolute;
      top: -4px;
      right: -6px;
      background: #ef4444;
      color: #fff;
      font-size: 10px;
      font-weight: 700;
      border-radius: 999px;
      padding: 1px 5px;
      line-height: 1.4;
    }

    .user-pill {
      display: flex;
      align-items: center;
      gap: 8px;
      background: rgba(255, 255, 255, .1);
      border-radius: 8px;
      padding: 5px 10px;
      cursor: pointer;
    }

    .user-pill .user-info,
    .user-pill .chevron {
      display: flex;
    }

    .avatar {
      width: 30px;
      height: 30px;
      border-radius: 50%;
      background: var(--blue);
      color: #fff;
      font-weight: 700;
      font-size: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .user-info {
      line-height: 1.3;
    }

    .user-info .uname {
      color: #fff;
      font-weight: 600;
      font-size: 13px;
    }

    .user-info .urole {
      color: #93c5fd;
      font-size: 11px;
    }

    .chevron {
      color: #93c5fd;
      font-size: 12px;
    }

    /* ── LAYOUT ── */
    .layout {
      display: flex;
      flex: 1;
      overflow: hidden;
      height: calc(100vh - 56px);
    }

    /* ── MAIN (left) ── */
    .main-panel {
      flex: 1;
      overflow-y: auto;
      padding: 24px;
      min-width: 0;
    }

    .section-header {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 20px;
    }

    .section-icon {
      width: 44px;
      height: 44px;
      border: 2px solid var(--border);
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 20px;
      background: #fff;
      flex-shrink: 0;
    }

    .section-header h1 {
      font-size: 22px;
      font-weight: 700;
    }

    .section-header p {
      font-size: 13px;
      color: var(--muted);
    }

    /* search + filter bar */
    .toolbar {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 20px;
      flex-wrap: wrap;
    }

    .search-wrap {
      flex: 1;
      min-width: 180px;
      position: relative;
    }

    .search-wrap input {
      width: 100%;
      padding: 9px 14px 9px 38px;
      border: 1px solid var(--border);
      border-radius: 8px;
      font-family: inherit;
      font-size: 14px;
      outline: none;
      background: #fff;
      transition: border .2s;
    }

    .search-wrap input:focus {
      border-color: var(--blue);
    }

    .search-icon {
      position: absolute;
      left: 12px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--muted);
      font-size: 15px;
    }

    .btn-filter {
      display: flex;
      align-items: center;
      gap: 6px;
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 9px 14px;
      font-family: inherit;
      font-size: 14px;
      cursor: pointer;
      font-weight: 500;
      white-space: nowrap;
    }

    .sort-wrap {
      display: flex;
      align-items: center;
      gap: 8px;
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 9px 14px;
      font-size: 14px;
      white-space: nowrap;
    }

    .sort-wrap span {
      color: var(--muted);
      font-size: 13px;
    }

    .sort-wrap select {
      border: none;
      outline: none;
      font-family: inherit;
      font-size: 14px;
      font-weight: 500;
      background: transparent;
      cursor: pointer;
    }

    /* grid */
    .orders-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 14px;
    }

    .order-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 18px;
      box-shadow: var(--shadow);
      transition: box-shadow .2s, transform .2s;
    }

    .order-card:hover {
      box-shadow: 0 4px 14px rgba(0, 0, 0, .1);
      transform: translateY(-1px);
    }

    .badge-active {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      background: var(--badge-active-bg);
      color: var(--badge-active-txt);
      font-size: 11px;
      font-weight: 600;
      padding: 3px 8px;
      border-radius: 999px;
      margin-bottom: 8px;
    }

    .badge-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--blue);
    }

    .order-code {
      font-size: 20px;
      font-weight: 700;
      color: var(--blue);
      margin-bottom: 12px;
    }

    .order-meta {
      display: flex;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 14px;
    }

    .meta-item label {
      display: block;
      font-size: 11px;
      color: var(--muted);
      margin-bottom: 2px;
    }

    .meta-item span {
      font-size: 13px;
      font-weight: 600;
    }

    .card-actions {
      display: flex;
      gap: 8px;
    }

    .btn-see {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      border: 1px solid var(--border);
      border-radius: 7px;
      padding: 8px;
      font-family: inherit;
      font-size: 13px;
      font-weight: 500;
      background: #fff;
      cursor: pointer;
      transition: background .15s;
    }

    .btn-see:hover {
      background: var(--bg);
    }

    .btn-review {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      background: var(--blue);
      color: #fff;
      border: none;
      border-radius: 7px;
      padding: 8px;
      font-family: inherit;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      transition: background .15s;
    }

    .btn-review:hover {
      background: var(--blue-h);
    }

    /* ── CHAT (right) ── */
    .chat-panel {
      width: 340px;
      flex-shrink: 0;
      background: #fff;
      border-left: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      overflow: hidden;
      transition: transform .3s ease, width .3s ease;
    }

    /* Botón para abrir/cerrar chat en móvil */
    .chat-toggle-btn {
      display: none;
      position: fixed;
      bottom: 20px;
      right: 20px;
      z-index: 100;
      background: var(--blue);
      color: #fff;
      border: none;
      border-radius: 50%;
      width: 52px;
      height: 52px;
      font-size: 22px;
      cursor: pointer;
      box-shadow: 0 4px 14px rgba(26, 86, 219, .4);
      align-items: center;
      justify-content: center;
    }

    /* Overlay oscuro para móvil cuando el chat está abierto */
    .chat-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, .4);
      z-index: 49;
    }

    .chat-header {
      padding: 18px 20px 14px;
      border-bottom: 1px solid var(--border);
      flex-shrink: 0;
    }

    .chat-header-top {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 14px;
    }

    .chat-header-top .icon {
      font-size: 18px;
      color: var(--muted);
    }

    .chat-header-top h2 {
      font-size: 16px;
      font-weight: 700;
      flex: 1;
    }

    /* Botón cerrar chat (solo visible en móvil) */
    .chat-close-btn {
      display: none;
      background: none;
      border: none;
      cursor: pointer;
      font-size: 20px;
      color: var(--muted);
      padding: 2px 6px;
    }

    .selected-order {
      background: var(--bg);
      border-radius: 8px;
      padding: 12px 14px;
    }

    .selected-label {
      font-size: 11px;
      color: var(--muted);
      margin-bottom: 2px;
    }

    .selected-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 6px;
    }

    .selected-code {
      font-size: 22px;
      font-weight: 800;
      color: var(--navy);
    }

    .change-btn {
      background: none;
      border: none;
      color: var(--blue);
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 4px;
    }

    .status-active {
      display: flex;
      align-items: center;
      gap: 5px;
      font-size: 12px;
      font-weight: 600;
      color: var(--green);
      margin-top: 4px;
    }

    .status-dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: var(--green);
    }

    /* messages */
    .chat-messages {
      flex: 1;
      overflow-y: auto;
      padding: 16px 20px;
      display: flex;
      flex-direction: column;
      gap: 14px;
    }

    .day-divider {
      text-align: center;
      font-size: 11px;
      color: var(--muted);
      background: var(--bg);
      padding: 3px 10px;
      border-radius: 999px;
      align-self: center;
    }

    .msg {
      display: flex;
      gap: 10px;
    }

    .msg-avatar {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      font-weight: 700;
      font-size: 11px;
      color: #fff;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      margin-top: 2px;
    }

    .av-am {
      background: #2563eb;
    }

    .av-aa {
      background: #7c3aed;
    }

    .msg-meta {
      display: flex;
      gap: 8px;
      align-items: baseline;
      margin-bottom: 3px;
    }

    .msg-name {
      font-size: 13px;
      font-weight: 700;
    }

    .msg-time {
      font-size: 11px;
      color: var(--muted);
    }

    .msg-text {
      font-size: 13px;
      line-height: 1.5;
      color: #374151;
      background: var(--bg);
      padding: 8px 12px;
      border-radius: 0 8px 8px 8px;
      display: inline-block;
      max-width: 240px;
      word-break: break-word;
    }

    .msg-text.own {
      background: #dbeafe;
    }

    /* input */
    .chat-input-wrap {
      padding: 12px 16px;
      border-top: 1px solid var(--border);
      flex-shrink: 0;
    }

    .chat-input-row {
      display: flex;
      align-items: center;
      gap: 8px;
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 9px;
      padding: 6px 10px;
      margin-bottom: 8px;
    }

    .chat-input-row input {
      flex: 1;
      border: none;
      background: transparent;
      font-family: inherit;
      font-size: 13px;
      outline: none;
      min-width: 0;
    }

    .icon-btn {
      background: none;
      border: none;
      cursor: pointer;
      color: var(--muted);
      font-size: 16px;
      display: flex;
      flex-shrink: 0;
    }

    .btn-send {
      background: var(--blue);
      color: #fff;
      border: none;
      border-radius: 7px;
      padding: 7px 14px;
      font-family: inherit;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      white-space: nowrap;
      flex-shrink: 0;
    }

    .chat-notice {
      font-size: 11px;
      color: var(--muted);
      background: #f9fafb;
      border: 1px solid var(--border);
      border-radius: 7px;
      padding: 8px 10px;
      display: flex;
      gap: 6px;
      align-items: flex-start;
    }

    .chat-notice .ni {
      font-size: 14px;
      flex-shrink: 0;
    }

    /* ════════════════════════════════════════
       RESPONSIVE — TABLET  (≤ 1024px)
       Panel de chat se estrecha
    ════════════════════════════════════════ */
    @media (max-width: 1024px) {
      .chat-panel {
        width: 300px;
      }

      .company-badge {
        max-width: 160px;
        font-size: 12px;
      }
    }

    /* ════════════════════════════════════════
       RESPONSIVE — TABLET PEQUEÑA  (≤ 768px)
       Chat se convierte en drawer lateral
    ════════════════════════════════════════ */
    @media (max-width: 768px) {

      /* Nav */
      .company-badge .full {
        display: none;
      }

      .company-badge .short {
        display: inline;
      }

      .company-badge {
        max-width: 120px;
      }

      .topnav-center .page-sub {
        display: none;
      }

      .user-pill .user-info,
      .user-pill .chevron {
        display: none;
      }

      .user-pill {
        padding: 5px;
      }

      /* Layout: main ocupa todo el ancho */
      .layout {
        height: calc(100vh - 56px);
        position: relative;
      }

      .main-panel {
        padding: 16px;
        width: 100%;
      }

      /* Chat drawer deslizante desde la derecha */
      .chat-panel {
        position: fixed;
        top: 56px;
        right: 0;
        bottom: 0;
        width: 320px;
        z-index: 50;
        transform: translateX(100%);
        border-left: 1px solid var(--border);
        box-shadow: -4px 0 20px rgba(0, 0, 0, .15);
      }

      .chat-panel.open {
        transform: translateX(0);
      }

      .chat-overlay.active {
        display: block;
      }

      /* FAB para abrir el chat */
      .chat-toggle-btn {
        display: flex;
      }

      /* Botón X dentro del header del chat */
      .chat-close-btn {
        display: block;
      }

      /* Grid de órdenes: 2 columnas */
      .orders-grid {
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      }

      /* Toolbar: buscador ocupa fila completa */
      .toolbar {
        flex-wrap: wrap;
      }

      .search-wrap {
        flex: 1 1 100%;
      }

      .section-header h1 {
        font-size: 18px;
      }
    }

    /* ════════════════════════════════════════
       RESPONSIVE — MÓVIL  (≤ 480px)
    ════════════════════════════════════════ */
    @media (max-width: 480px) {
      .main-panel {
        padding: 12px;
      }

      .company-badge {
        display: none;
      }

      .topnav {
        padding: 0 12px;
      }

      /* Grid: 1 sola columna */
      .orders-grid {
        grid-template-columns: 1fr;
      }

      .order-card {
        padding: 14px;
      }

      .order-code {
        font-size: 17px;
      }

      /* Toolbar compacta */
      .btn-filter span {
        display: none;
      }

      .sort-wrap span {
        display: none;
      }

      /* Chat drawer ocupa casi toda la pantalla */
      .chat-panel {
        width: 100%;
        max-width: 380px;
      }

      .section-header h1 {
        font-size: 16px;
      }

      .section-icon {
        width: 36px;
        height: 36px;
        font-size: 16px;
      }
    }

    /* === OVERLAY / MODAL BASE === */
    .preview-overlay {
      display: none;
      position: fixed;
      inset: 0;
      z-index: 999;
      background: rgba(0, 0, 0, 0.35);
      align-items: center;
      justify-content: center;
      padding: 16px;
    }

    .preview-overlay.open {
      display: flex;
    }

    /* === CARD CONTENEDOR === */
    .preview-product-card {
      background: #1a1f2e;
      border: 1px solid #3a4155;
      border-radius: 10px;
      width: 740px;
      max-width: 95vw;
      max-height: 90vh;
      overflow-y: auto;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5);
      animation: slideDown 0.18s ease;
    }

    @keyframes slideDown {
      from {
        opacity: 0;
        transform: translateY(-10px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    /* === HEADER DEL MODAL (topbar oscuro) === */
    .ppc-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px 16px;
      border-bottom: 1px solid #2a3040;
    }

    .ppc-codigo {
      font-family: monospace;
      font-size: 13px;
      font-weight: 600;
      color: #7eb3f5;
    }

    .ppc-close {
      background: transparent;
      border: none;
      color: #8892a4;
      font-size: 14px;
      cursor: pointer;
      padding: 0;
      line-height: 1;
    }

    .ppc-close:hover {
      color: #fff;
    }

    /* === CUERPO DEL MODAL === */
    .ppc-body {
      padding: 14px 16px;
      background: #fff;
      /* el interior de la guía es blanco */
      border-radius: 0 0 10px 10px;
    }

    /* === BARRA AZUL SUPERIOR DE LA GUÍA === */
    .guia-header {
      background: #1a3a5c;
      color: #fff;
      padding: 8px 12px;
      border-radius: 6px;
      display: flex;
      justify-content: space-between;
      font-size: 11px;
      margin-bottom: 14px;
      flex-wrap: wrap;
      gap: 6px;
    }

    /* === ENCABEZADO: logo + info empresa + número doc === */
    .preview-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 16px;
      padding-bottom: 14px;
      border-bottom: 1px solid #eee;
      flex-wrap: wrap;
      gap: 12px;
    }

    .ph-left {
      display: flex;
      gap: 12px;
      flex: 1;
      min-width: 200px;
    }

    .logo-box {
      width: 56px;
      height: 56px;
      background: #f5f5f5;
      border: 1px solid #ddd;
      border-radius: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 9px;
      color: #aaa;
      flex-shrink: 0;
    }

    .ph-info strong {
      font-size: 12px;
      font-weight: 600;
      color: #222;
      display: block;
      margin-bottom: 2px;
    }

    .ph-info p {
      font-size: 11px;
      color: #666;
      line-height: 1.7;
    }

    .ph-right {
      text-align: right;
    }

    .doc-num {
      font-size: 22px;
      font-weight: 600;
      color: #0f4c81;
    }

    .doc-meta {
      font-size: 11px;
      color: #888;
      margin-top: 2px;
    }

    /* === GRID DE DATOS DEL CLIENTE === */
    .client-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3px 24px;
      margin-bottom: 16px;
    }

    @media (max-width: 520px) {
      .client-grid {
        grid-template-columns: 1fr;
      }
    }

    .cl {
      font-size: 11px;
      color: #555;
      display: flex;
      gap: 4px;
    }

    .cl span:first-child {
      font-weight: 600;
      color: #333;
      min-width: 72px;
      flex-shrink: 0;
    }

    /* === TABLA DE ÍTEMS === */
    .table-wrap {
      width: 100%;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }

    .items-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 11px;
      margin-bottom: 14px;
      min-width: 480px;
    }

    .items-table th {
      background: #0f4c81;
      color: #fff;
      padding: 7px 8px;
      text-align: left;
      font-weight: 500;
      white-space: nowrap;
    }

    .items-table td {
      padding: 6px 8px;
      border-bottom: 1px solid #eee;
      color: #333;
    }

    .items-table tr:nth-child(even) td {
      background: #f9f9f9;
    }

    /* === TOTALES === */
    .totals {
      display: flex;
      justify-content: flex-end;
      margin-top: 4px;
    }

    .totals-box {
      width: 220px;
    }

    @media (max-width: 520px) {
      .totals-box {
        width: 100%;
      }
    }

    .total-row {
      display: flex;
      justify-content: space-between;
      font-size: 11px;
      padding: 3px 0;
      color: #666;
    }

    .total-final {
      display: flex;
      justify-content: space-between;
      font-size: 13px;
      font-weight: 600;
      padding: 7px 10px;
      background: #e85d14;
      color: #fff;
      border-radius: 6px;
      margin-top: 5px;
    }

    /* === FOOTER: condiciones / observaciones / contacto === */
    .preview-footer {
      margin-top: 20px;
      padding-top: 12px;
      border-top: 1px solid #eee;
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 10px;
    }

    @media (max-width: 600px) {
      .preview-footer {
        grid-template-columns: 1fr;
      }
    }

    .preview-footer strong {
      font-size: 10px;
      color: #555;
      font-weight: 600;
      display: block;
      margin-bottom: 2px;
    }

    .order-header {
