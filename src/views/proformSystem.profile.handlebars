  <script>
    /* ── Chat drawer (móvil/tablet) ── */
    const chatPanel = document.getElementById('chatPanel');
    const chatOverlay = document.getElementById('chatOverlay');
    const chatToggle = document.getElementById('chatToggleBtn');
    const chatClose = document.getElementById('chatCloseBtn');

    function openChat() {
      chatPanel.classList.add('open');
      chatOverlay.classList.add('active');
      document.body.style.overflow = 'hidden';
    }

    let activeToast;
    function toastSuccess(msg) {
      if (activeToast) activeToast.remove();

      const toast = document.createElement("div");
      activeToast = toast;

      toast.textContent = msg;
      toast.style.cssText = `
    position: fixed;
    top: 20px;
    left: 20px;
    background: #27ae60;
    color: white;
    padding: 10px 15px;
    border-radius: 6px;
    z-index: 9999;
    font-size: 14px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.2);
    opacity: 0;
    transform: translateY(10px);
    transition: all 0.3s ease;
  `;

      document.body.appendChild(toast);

      // animación entrada
      setTimeout(() => {
        toast.style.opacity = "1";
        toast.style.transform = "translateY(0)";
      }, 10);

      // salida
      setTimeout(() => {
        toast.style.opacity = "0";
        toast.style.transform = "translateY(10px)";

        setTimeout(() => {
          toast.remove();
          activeToast = null;
        }, 300);
      }, 2500);
    }

    function closeChat() {
      chatPanel.classList.remove('open');
      chatOverlay.classList.remove('active');
      document.body.style.overflow = '';
    }

    chatToggle.addEventListener('click', openChat);
    chatClose.addEventListener('click', closeChat);
    chatOverlay.addEventListener('click', closeChat);

    /* Cierra el drawer si se amplía la ventana */
    window.addEventListener('resize', () => {
      if (window.innerWidth > 768) closeChat();
    });

    /* ── Socket / Órdenes ── */
    const socket = io();
    let proformas = {{{ json proforms }}};

    const grid = {
      orders: document.querySelector('.orders-grid')
    };

    function printGuia(products) {
      const table = document.querySelector("#tbody-guia")
      table.innerHTML = ""

      for (let [i, product] of products.entries()) {

        for (let [j, option] of product.options.entries()) {

          const tr = document.createElement("tr")
          tr.classList.add(`guia_opcion_${product.index}`)
          tr.innerHTML = `
            <td>${j == 0 ? i + 1 : ""}</td>
            <td>${j == 0 ? product.cantidad : ""}</td>
            <td>${j == 0 ? `S/ ${product.monto}` : ""}</td>
        <td>${j == 0 ? product.nombre : ""}</td>
        <td>${j == 0 ? product.comentario : ""}</td>
              <td>${option.CODIGO_FORMATEADO}</td>
              
        <td>${option.STOCK_LV}</td>  
        <td>${option.STOCK_SJL}</td> 
  
        <td> ${option.DESCRIPCION} / ${option.FAMILIA} / ${option.SUBFAMILIA}</td >
        <td>${option.EQUIVALENTES_STOCK}</td>
        <td>${option.UBICACION}</td>
      `
          table.appendChild(tr)
        }
      }
    }


    function printRevision(products) {
      const table = document.querySelector("#tbody-revision")
      table.innerHTML = ""

      table.innerHTML = ""

      for (let [i, product] of products.entries()) {

        const productIndex = product.index
        const cantidad = product.cantidad

        for (let [j, option] of product.options.filter(o => o.status === true || o.status === "true").entries()) {

          // 👇 Índice REAL en el array sin filtrar
          const optionIndex = product.options.findIndex(o => o === option)

          const tr = document.createElement("tr")
          tr.classList.add(`guia_opcion_${product.index}`)
          tr.innerHTML = `
        <td>${j == 0 ? `<input type="checkbox" disabled ${product.isChecked ? "checked" : ""}>` : ""}</td>
        <td>${j == 0 ? i + 1 : ""}</td>
        <td>${j == 0 ? product.cantidad : ""}</td>
        <td>${j == 0 ? `S/ ${product.monto}` : ""}</td>
        <td>${j == 0 ? product.nombre : ""}</td>
        <td>${j == 0 ? product.comentario : ""}</td>
        <td>
          <div class="cmd-cell">
            <input class="cmd-input-qty" type="number" min="0" value="${option.CANTIDAD || 0}" disabled />
          </div>
        </td>
        <td>${option.CODIGO_FORMATEADO}</td>
        <td>${option.STOCK_LV}</td>
        <td>${option.STOCK_SJL}</td>
        <td>${option.DESCRIPCION} / ${option.FAMILIA} / ${option.SUBFAMILIA}</td>
        <td>${option.EQUIVALENTES_STOCK}</td>
        <td>${option.UBICACION}</td>
      `

          if (j === 0) {
            const checkbox = tr.querySelector("input[type='checkbox']")
            checkbox.addEventListener("change", async (e) => {
              const prodPos = currentProform.productos.findIndex(p => p.index === productIndex)
              if (prodPos !== -1) {
                currentProform.productos[prodPos].isChecked = e.target.checked
              }
              const filas = table.querySelectorAll(`.guia_opcion_${productIndex}`)
              filas.forEach(fila => fila.classList.toggle("fila-aprobada", e.target.checked))

              const ultimaFila = [...filas][filas.length - 1]
              ultimaFila.style.display = e.target.checked ? "none" : ""
            })
          }
          table.appendChild(tr)
        }

      }
    }

    function printRelacionales(products, order) {
      const table = document.querySelector("#tbody-relacionales")
      table.innerHTML = ""

      document.getElementById('pgClienteNombreRel').textContent = order.cliente.nombre
      document.getElementById('pgVendedorRel').textContent = order.vendedor
      document.getElementById('pgFechaRel').textContent = order.fecha

      for (let product of products) {
        for (let option of product.options) {
          const cantidad = option.CANTIDAD || 0
          if (cantidad <= 0) continue

          const monto = parseFloat(product.monto) || 0
          const importeTotal = cantidad * monto

          const tr = document.createElement("tr")
          tr.innerHTML = `
        <td>${order.fecha}</td>
        <td>${option.CODIGO_FORMATEADO}</td>
        <td>${cantidad}</td>
        <td>S/ ${monto.toFixed(2)}</td>
        <td>S/ ${importeTotal.toFixed(2)}</td>
        <td>${option.DESCRIPCION} / ${option.FAMILIA} / ${option.SUBFAMILIA}</td>
      `
          table.appendChild(tr)
        }
      }
    }
    function ioToEmit(data) {
      socket.emit("updatedProforms", data);
    }


  function crearImgThumb(foto) {
    const img = document.createElement('img')
    img.src = foto
    img.style.cssText = 'width:120px;height:120px;object-fit:cover;border-radius:6px;border:1px solid #ddd;cursor:pointer'
    img.onclick = () => {
      const overlay = document.createElement('div')
      overlay.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,0.85);z-index:9999;display:flex;align-items:center;justify-content:center;cursor:pointer'
      overlay.onclick = () => overlay.remove()
      const imgGrande = document.createElement('img')
      imgGrande.src = foto
      imgGrande.style.cssText = 'max-width:90vw;max-height:90vh;border-radius:8px;object-fit:contain'
      overlay.appendChild(imgGrande)
      document.body.appendChild(overlay)
    }
    return img
  }

  function printImagenes(products, order) {
    document.getElementById('pgClienteNombreImg').textContent = order.cliente.nombre
    document.getElementById('pgVendedorImg').textContent = order.vendedor
    document.getElementById('pgFechaImg').textContent = order.fecha

    const container = document.getElementById('view-imagenes')
    const existente = container.querySelector('.imagenes-grid')
    if (existente) existente.remove()

    const grid = document.createElement('div')
    grid.className = 'imagenes-grid'
    grid.style.cssText = 'display:flex;flex-direction:column;gap:16px;padding:12px 0'

    for (let product of products) {
      if (!product.fotos || product.fotos.length === 0) continue
      const bloque = document.createElement('div')
      bloque.style.cssText = 'border:1px solid #eee;border-radius:8px;overflow:hidden'
      const header = document.createElement('div')
      header.style.cssText = 'background:#f7f7f7;padding:8px 12px;font-size:11px;font-weight:600;color:#333;border-bottom:1px solid #eee'
      header.textContent = `${product.nombre} — ${product.cantidad} uds × S/ ${product.monto}`
      bloque.appendChild(header)
      const fotosWrap = document.createElement('div')
      fotosWrap.style.cssText = 'display:flex;flex-wrap:wrap;gap:8px;padding:10px'
      for (let foto of product.fotos) {
        fotosWrap.appendChild(crearImgThumb(foto))
      }
      bloque.appendChild(fotosWrap)
      grid.appendChild(bloque)
    }

    if (order.revision && order.revision.length > 0) {
      const bloque = document.createElement('div')
      bloque.style.cssText = 'border:1px solid #eee;border-radius:8px;overflow:hidden'
      const header = document.createElement('div')
      header.style.cssText = 'background:#e8f4fd;padding:8px 12px;font-size:11px;font-weight:600;color:#1a56db;border-bottom:1px solid #eee'
      header.textContent = `📋 Fotos de revisión (${order.revision.length})`
      bloque.appendChild(header)
      const fotosWrap = document.createElement('div')
      fotosWrap.style.cssText = 'display:flex;flex-wrap:wrap;gap:8px;padding:10px'
      for (let foto of order.revision) {
        fotosWrap.appendChild(crearImgThumb(foto))
      }
      bloque.appendChild(fotosWrap)
      grid.appendChild(bloque)
    }

    if (grid.children.length === 0) {
      grid.innerHTML = '<p style="text-align:center;color:#aaa;font-size:12px;padding:20px">Sin imágenes en esta orden</p>'
    }

    container.appendChild(grid)
  }

    async function abrirVistaGuia(code) {
      const res = await fetch(`/api/proforms/${code}`).then(res => res.json());
      const order = res.payload.payload.doc;
      document.getElementById("sw-revision").style.display =
        order.tipo != "cerrada" ? "none" : ""
      document.getElementById("sw-relacionales").style.display =
        order.tipo != "cerrada" ? "none" : ""
      console.log("order: ", order)
      // reset al abrir
      switchView('proforma');

      // header compartido
      document.getElementById('pgCode').textContent = `${order.code} ver más...`;
      //header guia:
      document.getElementById('pfCode').textContent = order.code;
      document.getElementById('pgClienteNombre').textContent = order.cliente.nombre;
      document.getElementById('pgVendedor').textContent = order.vendedor;
      document.getElementById('pgFecha').textContent = order.fecha;
      //header revision:
      document.getElementById('pgClienteNombreRev').textContent = order.cliente.nombre;
      document.getElementById('pgVendedorRev').textContent = order.vendedor;
      document.getElementById('pgFechaRev').textContent = order.fecha;

      //header relacionales:
      document.getElementById('pgClienteNombreRel').textContent = order.cliente.nombre;
      document.getElementById('pgVendedorRel').textContent = order.vendedor;
      document.getElementById('pgFechaRel').textContent = order.fecha;

      // proforma
      document.getElementById('pfCode').textContent = `${order.code} v${order.version}`;
      document.getElementById('pfFecha').textContent = `Fecha: ${order.fecha}`;
      document.getElementById('pfCliente').textContent = order.cliente.nombre || '—';
      document.getElementById('pfTelefono').textContent = order.cliente.telefono || '—';
      document.getElementById('pfRuc').textContent = order.cliente.ruc || '—';
      document.getElementById('pfMail').textContent = order.cliente.email || '—';
      document.getElementById('pfDireccion').textContent = order.cliente.direccion || '—';
      document.getElementById('pfEntrega').textContent = order.entrega || '—';
      document.getElementById('pfProvincia').textContent = order.cliente.provincia || '—';
      document.getElementById('pfCiudad').textContent = order.cliente.ciudad || '—';
      document.getElementById('pfDestino').textContent = order.destino || '—';
      document.getElementById('pfCanal').textContent = order.canal_de_venta || '—';
      document.getElementById('pfPago').textContent = order.forma_de_pago || '—';
      document.getElementById('pfComprobante').textContent = order.comprobante || '—';
      document.getElementById('pfVendedor').textContent = order.vendedor || '—';

      const tbodyPf = document.getElementById('tbody-proforma');
      tbodyPf.innerHTML = '';
      let subtotal = 0;

      order.productos.forEach((p, i) => {
        const monto = parseFloat(p.monto) || 0;
        const importe = p.cantidad * monto;
        subtotal += importe;
        const tr = document.createElement('tr');
        tr.innerHTML = `
    <td>${i + 1}</td>
    <td>${p.nombre}</td>
    <td>${p.cantidad}</td>
    <td>S/ ${monto.toFixed(2)}</td>
    <td>S/ ${importe.toFixed(2)}</td>
  `;
        tbodyPf.appendChild(tr);
      });

      const igv = (order.comprobante === 'Factura' || order.comprobante === 'Boleta')
        ? subtotal * 0.18
        : 0;

      const total = subtotal + igv;

      document.getElementById('pfSubtotal').textContent = `S/ ${subtotal.toFixed(2)}`;
      document.getElementById('pfIgv').textContent = `S/ ${igv.toFixed(2)}`;
      document.getElementById('pfTotal').textContent = `S/ ${total.toFixed(2)}`;

      // tabla guia
      printGuia(order.productos);
      printRevision(order.productos)

      printImagenes(order.productos, order);
      printRelacionales(order.productos, order)
      document.getElementById('previewGuiaOverlay').classList.add('open');
    }
