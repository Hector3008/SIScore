  </div>

  <!-- FAB para abrir el chat (móvil/tablet) -->
  <button class="chat-toggle-btn" id="chatToggleBtn" aria-label="Abrir chat">💬</button>

  <script src="/socket.io/socket.io.js"></script>

  <script>
    /* ── Chat drawer (móvil/tablet) ── */
    const chatPanel = document.getElementById('chatPanel');
    const chatOverlay = document.getElementById('chatOverlay');
    const chatToggle = document.getElementById('chatToggleBtn');
    const chatClose = document.getElementById('chatCloseBtn');

    function openChat() {
      chatPanel.classList.add('open');
      chatOverlay.classList.add('active');
      document.body.style.overflow = 'hidden';
    }

    function closeChat() {
      chatPanel.classList.remove('open');
      chatOverlay.classList.remove('active');
      document.body.style.overflow = '';
    }

    chatToggle.addEventListener('click', openChat);
    chatClose.addEventListener('click', closeChat);
    chatOverlay.addEventListener('click', closeChat);

    /* Cierra el drawer si se amplía la ventana */
    window.addEventListener('resize', () => {
      if (window.innerWidth > 768) closeChat();
    });

    /* ── Socket / Órdenes ── */
    const socket = io();
    const proformsJSON = {{{ json proforms }}};

    const grid = {
      orders: document.querySelector('.orders-grid')
    };

    function printOrders(proforms) {
      grid.orders.innerHTML = '';

      for (let proform of proforms) {
        let card = document.createElement('div');
        card.classList.add('order-card');
        card.innerHTML = `
<div class="card-top">
  <div class="badge-active">
    <span class="badge-dot"></span>
    ACTIVA
  </div>
  <span class="badge-tipo">${proform.payload.doc.tipo}</span>
</div>
  
  <div class="order-header">
    <div class="order-code">${proform.payload.doc.code}</div>
    <button style="margin: 0.2rem" class="btn-see">👁 Ver más</button>
  </div>
  <div class="order-meta">
    <div class="meta-item">
      <label>Cliente</label>
      <span>${proform.payload.doc.cliente.nombre}</span>
    </div>
    <div class="meta-item">
      <label>Vendedor</label>
      <span>${proform.payload.doc.vendedor}</span>
    </div>
    <div class="meta-item" style="text-align:right">
      <label>Fecha</label>
      <span>${proform.payload.doc.fecha}</span>
    </div>
  </div>
  <div class="card-actions">
    <button class="btn-review" data-code="${proform.payload.doc.code}">↗ Facturar</button>
    <button class="btn-review" data-code="${proform.payload.doc.code}">▯ Comprobante</button>
  </div>
`;

        grid.orders.appendChild(card);
      }
    }

    printOrders(proformsJSON);

    async function getProforms() {
      try {
        const response = await fetch('/api/proforms');
        const data = await response.json();
        return data.payload;
      } catch (err) {
        console.error(err);
        return null;
      }
    }

    async function enviaraRevision(code) {
      const res = await fetch(`/api/proforms/${code}`).then(res => res.json());
      const order = res.payload.payload.doc;
      order.tipo = 'orden_revision';

      try {
        await fetch(`/api/proforms/${code}`, {
          method: 'PUT',
          body: JSON.stringify(order),
          headers: { 'Content-Type': 'application/json' },
        });
      } catch (error) {
        console.error('Error:', error);
      }

      const proforms = await getProforms();
      printOrders(proforms);
    }

    socket.on('updatedProforms', (data) => {
      printOrders(data);
    });

    grid.orders.addEventListener('click', (e) => {
      if (e.target.classList.contains('btn-review')) {
        const btn = e.target.closest('.btn-review');
        if (btn) {
          const code = btn.dataset.code;
          enviaraRevision(code);
        }
      }
    });
  </script>
</body>

</html>