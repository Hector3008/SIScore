    fields.forma_de_pago.addEventListener("change", (e) => {
      currentProform.forma_de_pago = e.target.value
      proformPreview.forma_de_pago.textContent = e.target.value
    })
    //comprobante ✅
    fields.comprobante.addEventListener("change", (e) => {
      currentProform.comprobante = e.target.value
      proformPreview.comprobante.textContent = e.target.value
    })
    //boton cargar pago✅
    botones.cargarPago.addEventListener("click", (e) => {
      e.preventDefault()
      const pago = {
        index: currentProform.pagos.length + 1,
        status: true,
        monto: fields.pago.monto.value,
        operacion: fields.pago.operacion.value,
        cuenta: fields.pago.cuenta.value
      }
      currentProform.pagos.push(pago)
      //pagos para cargar en la tabla:
      const pagos = currentProform.pagos.filter(e => e.status === true)

      function resetFields() {
        fields.pago.monto.value = ""
        fields.pago.operacion.value = ""
        fields.pago.cuenta.value = ""
      }
      resetFields()
      printPagos(pagos)

    })
    //boton borrar pago ✅
    tables.pagos.addEventListener("click", (e) => {

      if (e.target.id.startsWith("btn_eliminar_pago_")) {
        console.log("here!!")
        const tr = e.target.closest("tr");
        const id = tr.id.split("_")[1]
        tr.remove()
        const proforma_pago = document.querySelector(`#proforma_pago_${id}`)
        proforma_pago.remove()
        const pago = currentProform.pagos.find(p => p.index == id)
        if (pago) {
          pago.status = false
        }
      }
    })

//product search
  fields.products.product.addEventListener("input",(e)=>{
  //console.log("hello from here")
  
    const search = e.target.value.toLowerCase().trim();
    const tokens = search.split(/\s+/).filter(Boolean);

    const filter = catalog.filter(p=>{
      {
        const text = `
          ${p.CODIGO_FORMATEADO}
          ${p.CODIGO}
          ${p.DESCRIPCION}
          ${p.PROVEEDOR}
          ${p.MARCA}
          ${p.SUBFAMILIA}
          ${p.FAMILIA}
        `.toLowerCase();
        // 👇 TODAS las palabras deben existir

        return tokens.every(word => text.includes(word))
      }
    })
    
    printProductSearch(filter)
  })
  }

  conexiones()

</script>