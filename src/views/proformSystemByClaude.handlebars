  <script>//responsive:
    /* Ocultar el bloque desktop en mobile y viceversa */
    const desktopActions = document.getElementById('desktopActions');
    function applyLayout() {
      if (window.innerWidth < 900) {
        desktopActions.style.display = 'none';
      } else {
        desktopActions.style.display = 'contents';
      }
    }
    applyLayout();
    window.addEventListener('resize', applyLayout);

    function toggleSection(header) {
      const body = header.nextElementSibling;
      const arrow = header.querySelector('span');
      if (body.style.display === 'none') {
        body.style.display = 'flex';
        arrow.textContent = '▾';
      } else {
        body.style.display = 'none';
        arrow.textContent = '▸';
      }
    }

    function switchTab(name, el) {
      document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
      document.getElementById('tab-' + name).classList.add('active');
      el.classList.add('active');
    }

    const cant = document.getElementById('inputCantidad');
    const precio = document.getElementById('inputPrecio');
    const totalItem = document.getElementById('totalItem');
    function calcTotal() {
      const c = parseFloat(cant.value) || 0;
      const p = parseFloat(precio.value) || 0;
      totalItem.textContent = 'S/ ' + (c * p).toFixed(2);
    }
    cant.addEventListener('input', calcTotal);
    precio.addEventListener('input', calcTotal);

    function consultarProforma() { }
    function actualizarProforma() { }
    function cargarProforma() { }
    function reiniciarFormulario() { }
  </script>
