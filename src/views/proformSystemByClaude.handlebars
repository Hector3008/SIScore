      }

      .sidebar-label {
        display: flex;
      }

      /* Body en grid 2 col con scroll independiente */
      .body-area {
        flex: 1;
        min-height: 0;
        display: grid;
        grid-template-columns: 300px 1fr;
      }

      .sidebar {
        overflow-y: auto;
        overflow-x: hidden;
      }

      .main {
        overflow-y: auto;
        overflow-x: hidden;
      }
